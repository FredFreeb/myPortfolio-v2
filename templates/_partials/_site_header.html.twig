<header class="site-header">
    <a class="brand" href="{{ path('app_home') }}">
        <span class="brand__mark">
            <img src="{{ asset('images/profile/fred-public-avatar.jpg') }}" alt="Photo de profil LinkedIn de Frederic Fribel">
        </span>
        <span class="brand__text">
            <strong>Frédéric</strong>
            <small>Fribel</small>
        </span>
    </a>

    <button
        class="nav-toggle"
        type="button"
        aria-label="Ouvrir la navigation"
        aria-controls="site-header-panel"
        aria-expanded="false"
        data-nav-target="button"
        onclick="return window.portfolioNavToggle ? window.portfolioNavToggle(this) : false;"
    >
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
    </button>

    <div class="site-header__backdrop" data-nav-target="backdrop" onclick="return window.portfolioNavClose ? window.portfolioNavClose() : false;" hidden></div>

    <div class="site-header__panel" id="site-header-panel" data-nav-target="panel">
        <nav class="site-nav" aria-label="Navigation principale">
            <a class="site-nav__link {{ currentRoute == 'app_home' ? 'is-active' }}" href="{{ path('app_home') }}">Portfolio</a>
            <a class="site-nav__link {{ currentRoute == 'app_about' ? 'is-active' }}" href="{{ path('app_about') }}">About me</a>
            <a class="site-nav__link {{ currentRoute starts with 'app_civitalisme' ? 'is-active' }}" href="{{ path('app_civitalisme') }}">Civitalisme</a>
            <a class="site-nav__link {{ currentRoute == 'app_contact' ? 'is-active' }}" href="{{ path('app_contact') }}">Contact</a>
        </nav>
    </div>
</header>
