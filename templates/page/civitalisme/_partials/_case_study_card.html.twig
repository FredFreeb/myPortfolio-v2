<article class="surface-card case-study-card">
    <div class="case-study-card__header">
        <div>
            {% if caseStudy.eyebrow is defined %}
                <p class="panel-label">{{ caseStudy.eyebrow }}</p>
            {% endif %}
            <h3>{{ caseStudy.title }}</h3>
        </div>

        {% if caseStudy.summary is defined %}
            <p>{{ caseStudy.summary }}</p>
        {% endif %}
    </div>

    <div class="case-study-card__grid">
        {% if caseStudy.table is defined and caseStudy.table.rows is defined and caseStudy.table.rows %}
            <div class="case-study-card__panel case-study-card__panel--table">
                {% if caseStudy.table.title is defined and caseStudy.table.title %}
                    <p class="panel-label">{{ caseStudy.table.title }}</p>
                {% endif %}
                {% if caseStudy.table.caption is defined and caseStudy.table.caption %}
                    <p>{{ caseStudy.table.caption }}</p>
                {% endif %}

                <div class="comparison-table__scroll">
                    <table class="case-study-card__table">
                        <thead>
                            <tr>
                                <th scope="col">{{ caseStudy.table.rowLabel|default('Situation') }}</th>
                                {% for column in caseStudy.table.columns %}
                                    <th scope="col">{{ column.label }}</th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in caseStudy.table.rows %}
                                <tr>
                                    <th scope="row">{{ row.label }}</th>
                                    {% for column in caseStudy.table.columns %}
                                        <td>{{ attribute(row, column.key) }}</td>
                                    {% endfor %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

        {% if caseStudy.household is defined and caseStudy.household %}
            <div class="case-study-card__panel">
                <p class="panel-label">Configuration</p>
                <ul class="feature-list feature-list--tight">
                    {% for item in caseStudy.household %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if caseStudy.metrics is defined and caseStudy.metrics %}
            <div class="case-study-card__panel">
                <p class="panel-label">Repères</p>
                <div class="metric-strip metric-strip--stacked">
                    {% for metric in caseStudy.metrics %}
                        <div class="metric-chip">
                            <strong>{{ metric.value }}</strong>
                            <span>{{ metric.label }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if caseStudy.formulas is defined and caseStudy.formulas %}
            <div class="case-study-card__panel">
                <p class="panel-label">Calculs</p>
                <div class="formula-stack">
                    {% for formula in caseStudy.formulas %}
                        <p class="case-study-card__equation">{{ formula }}</p>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if caseStudy.before is defined and caseStudy.before %}
            <div class="case-study-card__panel">
                <p class="panel-label">Avant perte d’emploi</p>
                <ul class="feature-list feature-list--tight">
                    {% for item in caseStudy.before %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if caseStudy.after is defined and caseStudy.after %}
            <div class="case-study-card__panel">
                <p class="panel-label">Après perte d’emploi</p>
                <ul class="feature-list feature-list--tight">
                    {% for item in caseStudy.after %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>

    {% if caseStudy.effects is defined and caseStudy.effects %}
        <div class="case-study-card__footer">
            <div>
                <p class="panel-label">Lecture</p>
                <ul class="feature-list feature-list--tight">
                    {% for effect in caseStudy.effects %}
                        <li>{{ effect }}</li>
                    {% endfor %}
                </ul>
            </div>

            {% if caseStudy.conclusion is defined and caseStudy.conclusion %}
                <p class="section-note">{{ caseStudy.conclusion }}</p>
            {% endif %}
        </div>
    {% endif %}
</article>
