<!DOCTYPE html>
{% set _current_route = app.request.attributes.get('_route') %}
{% set _current_params = app.request.attributes.get('_route_params')|default({}) %}
{% set _locale = app.request.locale|default('fr') %}
{% set _og_locale_map = {'fr': 'fr_FR', 'en': 'en_US', 'de': 'de_DE', 'es': 'es_ES', 'cs': 'cs_CZ'} %}
<html lang="{{ _locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script>(function(){var s=localStorage.getItem('color-scheme');if(s&&s!=='auto')document.documentElement.setAttribute('data-color-scheme',s);}());</script>
    <title>{% block title %}Portfolio + Civitalisme{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Portfolio, parcours et projet Civitalisme dans une application Symfony sobre, éditable et maintenable.{% endblock %}">
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    {% if _current_route and '_locale' in _current_params|keys %}
        {% for locale in available_locales() %}
            <link rel="alternate" hreflang="{{ locale }}" href="{{ url(_current_route, _current_params|merge({'_locale': locale})) }}">
        {% endfor %}
        <link rel="alternate" hreflang="x-default" href="{{ url(_current_route, _current_params|merge({'_locale': 'fr'})) }}">
    {% endif %}
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    <meta property="og:locale" content="{{ _og_locale_map[_locale]|default(_locale ~ '_' ~ _locale|upper) }}">
    <meta property="og:site_name" content="Portfolio + Civitalisme — Frédéric Fribel">
    <meta property="og:title" content="{% block og_title %}{% if block('title') is not empty %}{{ block('title') }}{% else %}Portfolio + Civitalisme{% endif %}{% endblock %}">
    <meta property="og:description" content="{{ block('meta_description') }}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('images/profile/fred-linkedin-brand.jpg')) }}{% endblock %}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('meta_description') }}">
    <meta name="twitter:image" content="{{ block('og_image') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&display=swap">
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% block extra_head %}{% endblock %}
    {{ importmap('app') }}
    {# ── Analytics — GoatCounter (RGPD-compliant, sans cookie, open source) ── #}
    {# Pour activer : créer un compte sur goatcounter.com et remplacer CODE par votre identifiant #}
    {% if app.environment == 'prod' %}
    <script data-goatcounter="https://fribel.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
    {% endif %}
</head>
{% set currentRoute = app.request.attributes.get('_route') ?? '' %}
<body class="{% block body_class %}theme-portfolio{% endblock %}">
    <div class="site-background" aria-hidden="true">
        <div class="site-background__orb site-background__orb--one"></div>
        <div class="site-background__orb site-background__orb--two"></div>
        <div class="site-background__grid"></div>
    </div>

    <a href="#main-content" class="skip-link">Aller au contenu principal</a>
    <div class="site-shell">
        {% include '_partials/_site_header.html.twig' with {
            currentRoute: currentRoute,
        } only %}

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash--{{ label == 'error' ? 'error' : 'success' }}">
                    {{ message|trans }}
                </div>
            {% endfor %}
        {% endfor %}

        <main class="page-main" id="main-content">
            {% block body %}{% endblock %}
        </main>

        {% include '_partials/_site_footer.html.twig' %}
    </div>
</body>
</html>
