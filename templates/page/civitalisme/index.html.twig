                {% endfor %}
            </svg>
        </div>

        <p class="gp-solution__subtext">{{ content.solution.subtext }}</p>

        {% if content.solution.closedLoop is defined %}
        <div class="gp-solution__loop-note surface-card">
            <p class="gp-solution__loop-note__title">{{ content.solution.closedLoop.title }}</p>
            <p class="gp-solution__loop-note__body">{{ content.solution.closedLoop.body }}</p>
        </div>
        {% endif %}
    </section>


    {# ── 4b. Schémas pédagogiques ───────────────────────────────────────── #}
    <section class="section section--panel section--alt gp-schemas" aria-labelledby="schemas-title">
        <div class="ped-intro">
            <p class="eyebrow">Comprendre le mécanisme</p>
            <h2 id="schemas-title">Comment ça fonctionne, vraiment</h2>
            <p>Deux schémas pour comprendre le mécanisme du SVG et comment il s'intègre dans l'économie.</p>
        </div>

        {# ── SCHÉMA 1 — Le mécanisme CDC ── #}
        <div class="ped-schema">
            <div class="ped-schema-header bg-navy">
                <div class="ped-badge bg-gold">1</div>
                <div>
                    <h3>Comment le CDC est créé et circule</h3>
                    <p>Du contrôle de la BCE jusqu'à la carte dans votre poche</p>
                </div>
            </div>
            <div class="ped-body">

                {# Zone supervision #}
                <div class="ped-zone bg-navy-lt b-navy">
                    <div class="ped-zone-label c-navy">🏛 Supervision — Banque Centrale Européenne (BCE)</div>
                    <div class="ped-nodes">
                        <div class="ped-node bg-navy" style="flex:2">
                            <div class="ped-node-icon">🏛</div>
                            <div class="ped-node-title">La BCE supervise</div>
                            <div class="ped-node-sub">Elle fixe les règles — elle ne verse pas d'argent directement.</div>
                            <div class="ped-node-tag bg-gold">Contrôle, pas transfert</div>
                        </div>
                        <div class="ped-node bg-navy-lt b-navy" style="flex:3">
                            <div class="ped-node-icon">📋</div>
                            <div class="ped-node-title c-navy">Ce que la BCE décide</div>
                            <div class="ped-points">
                                <div class="ped-point"><div class="ped-dot bg-navy">1</div><span>Le montant du <strong>panier vital annuel</strong> (voté par le Parlement européen)</span></div>
                                <div class="ped-point"><div class="ped-dot bg-navy">2</div><span>Les <strong>seuils d'éligibilité</strong> et les paramètres de calcul</span></div>
                                <div class="ped-point"><div class="ped-dot bg-navy">3</div><span>La <strong>masse totale de CDC</strong> autorisée en circulation</span></div>
                                <div class="ped-point"><div class="ped-dot bg-navy">4</div><span>L'<strong>audit des banques</strong> opératrices certifiées</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#003399"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #003399"></div>
                    </div>
                    <div class="ped-arrow-label bg-navy-lt c-navy">Paramètres transmis aux banques</div>
                </div>

                {# Zone génération #}
                <div class="ped-zone bg-gold-soft b-gold">
                    <div class="ped-zone-label c-gold">🏦 Génération — Banques commerciales</div>
                    <div class="ped-nodes">
                        <div class="ped-node bg-gold">
                            <div class="ped-node-icon">🏦</div>
                            <div class="ped-node-title">Votre banque calcule</div>
                            <div class="ped-node-sub">Chaque mois, automatiquement, sans que vous demandiez quoi que ce soit.</div>
                            <div class="ped-node-tag bg-navy" style="color:white">Opérateur certifié BCE</div>
                        </div>
                        <div class="ped-node bg-white b-gold" style="flex:2;border:2px solid #ffcc00">
                            <div class="ped-node-icon">🧮</div>
                            <div class="ped-node-title c-navy">La formule</div>
                            <div style="background:#003399;color:white;border-radius:8px;padding:.6rem .9rem;font-size:.9rem;font-weight:800;text-align:center;margin:.4rem 0">
                                Panier vital — Vos ressources = CDC à créditer
                            </div>
                            <div class="ped-node-sub c-grey">Si le résultat est positif, votre compte CDC est crédité. Si vos ressources dépassent le panier vital, rien n'est versé.</div>
                        </div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#b38a00"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #b38a00"></div>
                    </div>
                    <div class="ped-arrow-label bg-gold-soft c-gold">Crédit sur le réseau européen</div>
                </div>

                {# Zone rails #}
                <div class="ped-zone bg-grey-lt b-grey" style="padding:.75rem">
                    <div class="ped-zone-label c-grey">⚡ Deux réseaux de paiement qui coexistent — sans se mélanger</div>
                    <div class="ped-rails">
                        <div class="ped-rail bg-grey-lt b-grey b-dashed">
                            <div class="ped-node-icon" style="font-size:1.2rem">💳</div>
                            <div style="font-size:.85rem;font-weight:800;color:#6b7280;margin:.25rem 0">Visa / Mastercard</div>
                            <div style="font-size:.75rem;color:#6b7280;line-height:1.4">Réseau privé américain — vos euros habituels.<br><strong>Inchangé. Le SVG ne le touche pas.</strong></div>
                            <div style="margin-top:.5rem;padding:.3rem .6rem;background:#e5e7eb;border-radius:6px;font-size:.72rem;color:#6b7280;font-weight:700">Votre carte bancaire classique</div>
                        </div>
                        <div class="ped-rail-divider">≠</div>
                        <div class="ped-rail bg-navy-lt b-navy">
                            <div class="ped-node-icon" style="font-size:1.2rem">🇪🇺</div>
                            <div style="font-size:.85rem;font-weight:800;color:#003399;margin:.25rem 0">TIPS · TARGET · Wero</div>
                            <div style="font-size:.75rem;color:#003399;line-height:1.4">Infrastructure publique européenne (BCE).<br><strong>Indépendant · Souverain · Aucun acteur privé US.</strong></div>
                            <div style="margin-top:.5rem;padding:.3rem .6rem;background:#003399;border-radius:6px;font-size:.72rem;color:#ffcc00;font-weight:700">Votre carte CDC — dépenses vitales uniquement</div>
                        </div>
                    </div>
                    <div class="ped-callout bg-navy-lt">
                        <div class="ped-callout-icon">💡</div>
                        <div><strong>Pourquoi deux réseaux séparés ?</strong> Pour garantir la souveraineté européenne. L'argent CDC ne peut pas transiter par des systèmes contrôlés hors UE ni être extrait du circuit économique européen.</div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#003399"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #003399"></div>
                    </div>
                    <div class="ped-arrow-label bg-navy" style="color:#ffcc00">Crédité sur votre Compte de Dépenses Conditionnées</div>
                </div>

                {# Zone citoyen #}
                <div class="ped-nodes" style="margin-bottom:1rem">
                    <div class="ped-node bg-navy" style="flex:1;align-items:center;text-align:center">
                        <div class="ped-node-icon">👤</div>
                        <div class="ped-node-title">Votre compte CDC</div>
                        <div class="ped-node-sub">Utilisable comme une carte bancaire ordinaire. Le commerçant ne voit aucune différence.</div>
                        <div class="ped-node-tag bg-gold" style="align-self:center">Ni retrait cash · Ni virement · Ni luxe</div>
                    </div>
                    <div class="ped-node bg-navy-lt b-navy" style="flex:2">
                        <div class="ped-node-icon">🛒</div>
                        <div class="ped-node-title c-navy">Utilisable pour les dépenses vitales</div>
                        <div class="ped-pills">
                            <span class="ped-pill">🏠 Loyer</span>
                            <span class="ped-pill">🥦 Alimentation</span>
                            <span class="ped-pill">⚡ Énergie</span>
                            <span class="ped-pill">🚌 Transport</span>
                            <span class="ped-pill">🏥 Santé</span>
                            <span class="ped-pill">📚 Éducation</span>
                        </div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#1a7a5e"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #1a7a5e"></div>
                    </div>
                    <div class="ped-arrow-label bg-green-lt c-green">Dépensé chez les commerçants agréés UE</div>
                </div>

                {# Zone boucle #}
                <div class="ped-nodes">
                    <div class="ped-node bg-green">
                        <div class="ped-node-icon">🏪</div>
                        <div class="ped-node-title">Commerçants agréés UE</div>
                        <div class="ped-node-sub">Convertissent le CDC en euros. Ils ne voient aucune différence avec un paiement normal.</div>
                    </div>
                    <div class="ped-node bg-green-lt b-green">
                        <div class="ped-node-icon">📋</div>
                        <div class="ped-node-title c-green">TVA collectée</div>
                        <div class="ped-node-sub c-green">Chaque achat CDC génère de la TVA → Trésor public → finance partiellement le SVG.</div>
                    </div>
                    <div class="ped-callout bg-green" style="flex:1;border-radius:12px">
                        <div class="ped-callout-icon">🔄</div>
                        <div style="font-size:.8rem"><strong>Boucle fermée.</strong> L'argent reste en Europe. Il ne peut pas partir offshore. Multiplicateur économique local maximal.</div>
                    </div>
                </div>

            </div>
        </div>

        {# ── SCHÉMA 2 — Flux économique ── #}
        <div class="ped-schema">
            <div class="ped-schema-header" style="background:#1a1a2e">
                <div class="ped-badge bg-red">2</div>
                <div>
                    <h3>Comment le SVG s'intègre dans l'économie</h3>
                    <p>Le circuit actuel et ce que le SVG vient corriger</p>
                </div>
            </div>
            <div class="ped-body">

                {# Partie A — Système actuel #}
                <div class="ped-zone bg-red-lt b-red b-dashed">
                    <div class="ped-zone-label c-red">⚠️ Le circuit capitaliste actuel — ses deux failles</div>

                    <div class="ped-steps">
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#6b7280">👨‍👩‍👧</div>
                            <div class="ped-step-label" style="color:#6b7280">Ménages</div>
                            <div class="ped-step-sub">Salariés, retraités, travailleurs</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#6b7280">💶</div>
                            <div class="ped-step-label" style="color:#6b7280">Salaires</div>
                            <div class="ped-step-sub">Versés par les entreprises</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#6b7280">🛒</div>
                            <div class="ped-step-label" style="color:#6b7280">Consommation</div>
                            <div class="ped-step-sub">Alimente les entreprises</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#6b7280">🏭</div>
                            <div class="ped-step-label" style="color:#6b7280">Entreprises</div>
                            <div class="ped-step-sub">Revenus, bénéfices</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num bg-red">📤</div>
                            <div class="ped-step-label c-red">Extraction</div>
                            <div class="ped-step-sub" style="color:#c0392b">Dividendes offshore — quitte le circuit réel</div>
                        </div>
                    </div>

                    <div class="ped-compare">
                        <div class="ped-compare-col bg-red-lt b-red" style="border:1.5px solid #c0392b">
                            <div class="ped-compare-title c-red"><span style="font-size:1.2rem">⚙️</span> Faille 1 — Automatisation</div>
                            <div class="ped-points">
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Emplois détruits ou transformés</span></div>
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Salaires mis sous pression</span></div>
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Temps partiel subi, missions courtes</span></div>
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Revenus insuffisants, fins de mois tendues</span></div>
                            </div>
                        </div>
                        <div class="ped-compare-col bg-red-lt b-red" style="border:1.5px solid #c0392b">
                            <div class="ped-compare-title c-red"><span style="font-size:1.2rem">🕳</span> Faille 2 — Extraction</div>
                            <div class="ped-points">
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Bénéfices envoyés dans des paradis fiscaux</span></div>
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Rachats d'actions — enrichit actionnaires, pas l'économie</span></div>
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span>Épargne non réinvestie dans le circuit réel</span></div>
                                <div class="ped-point"><div class="ped-dot bg-red">→</div><span><strong>La demande baisse → entreprises souffrent aussi</strong></span></div>
                            </div>
                        </div>
                    </div>

                    <div class="ped-callout bg-red">
                        <div class="ped-callout-icon">🔻</div>
                        <div><strong>Résultat : un spiral récessif.</strong> Moins de demande → moins d'emplois → moins de revenus → encore moins de demande. Le système se fragilise lui-même. Les entreprises en souffrent autant que les ménages.</div>
                    </div>
                </div>

                {# Transition #}
                <div class="ped-transition">
                    <div class="ped-transition-bar" style="background:linear-gradient(to right, #c0392b, #1a7a5e)"></div>
                    <div class="ped-transition-label">✦ Le SVG intervient ici ✦</div>
                    <div class="ped-transition-bar" style="background:linear-gradient(to right, #1a7a5e, #003399)"></div>
                </div>

                {# Partie B — Avec SVG #}
                <div class="ped-zone bg-green-lt b-green">
                    <div class="ped-zone-label c-green">✅ Le circuit avec SVG — ce qui change (et ce qui reste)</div>

                    <div class="ped-steps">
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#003399">🏛</div>
                            <div class="ped-step-label">BCE</div>
                            <div class="ped-step-sub">Fixe le panier vital</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#b38a00">🏦</div>
                            <div class="ped-step-label">Banque</div>
                            <div class="ped-step-sub">Calcule et crédite le CDC</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#003399">👤</div>
                            <div class="ped-step-label">Compte CDC</div>
                            <div class="ped-step-sub">Réseau européen TIPS</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#1a7a5e">🏪</div>
                            <div class="ped-step-label">Commerçants UE</div>
                            <div class="ped-step-sub">Convertissent en euros</div>
                        </div>
                        <div class="ped-step">
                            <div class="ped-step-num" style="background:#1a7a5e">🔄</div>
                            <div class="ped-step-label">TVA → Trésor</div>
                            <div class="ped-step-sub">Finance partiellement le SVG</div>
                        </div>
                    </div>

                    <div class="ped-compare">
                        <div class="ped-compare-col bg-green-lt b-green" style="border:1.5px solid #1a7a5e">
                            <div class="ped-compare-title c-green"><span style="font-size:1.2rem">✅</span> Ce que le SVG répare</div>
                            <div class="ped-points">
                                <div class="ped-point"><div class="ped-dot bg-green">✓</div><span><strong>Plancher de demande garanti</strong> — les ménages peuvent toujours consommer l'essentiel</span></div>
                                <div class="ped-point"><div class="ped-dot bg-green">✓</div><span><strong>Entreprises profitent aussi</strong> — nouveaux clients solvables pour l'alimentation, le logement, l'énergie</span></div>
                                <div class="ped-point"><div class="ped-dot bg-green">✓</div><span><strong>Spiral récessif stoppé</strong> — la demande ne peut plus s'effondrer sous un seuil vital</span></div>
                                <div class="ped-point"><div class="ped-dot bg-green">✓</div><span><strong>L'argent reste en Europe</strong> — pas d'extraction offshore possible</span></div>
                                <div class="ped-point"><div class="ped-dot bg-green">✓</div><span><strong>TVA générée</strong> — finance partiellement le mécanisme (boucle vertueuse)</span></div>
                            </div>
                        </div>
                        <div class="ped-compare-col bg-grey-lt b-grey">
                            <div class="ped-compare-title c-grey"><span style="font-size:1.2rem">◉</span> Ce qui ne change pas</div>
                            <div class="ped-points">
                                <div class="ped-point"><div class="ped-dot" style="background:#6b7280">◉</div><span>Vos <strong>salaires et revenus sont inchangés</strong></span></div>
                                <div class="ped-point"><div class="ped-dot" style="background:#6b7280">◉</div><span>Vos <strong>droits au chômage (ARE)</strong> sont maintenus</span></div>
                                <div class="ped-point"><div class="ped-dot" style="background:#6b7280">◉</div><span>Votre <strong>retraite est préservée</strong></span></div>
                                <div class="ped-point"><div class="ped-dot" style="background:#6b7280">◉</div><span>La <strong>propriété privée</strong> et le <strong>marché libre</strong> subsistent</span></div>
                                <div class="ped-point"><div class="ped-dot" style="background:#6b7280">◉</div><span>La <strong>concurrence entre entreprises</strong> reste entière</span></div>
                            </div>
                        </div>
                    </div>

                    <div class="ped-callout bg-green">
                        <div class="ped-callout-icon">🚀</div>
                        <div><strong>Un tremplin, pas un piège.</strong> Si vos revenus augmentent, votre SVG diminue progressivement — mais chaque euro gagné vous enrichit toujours. Travailler reste toujours plus rentable. Le SVG ne crée aucun seuil pénalisant.</div>
                    </div>

                    <div class="ped-callout bg-navy-lt" style="margin-top:.75rem">
                        <div class="ped-callout-icon">📊</div>
                        <div><strong>Coût net bien inférieur au montant distribué.</strong> La TVA générée, les économies sur les aides actuelles et la croissance de l'activité locale réduisent significativement le coût réel pour la collectivité.</div>
                    </div>
                </div>

            </div>
        </div>

    </section>

    {# ── 5. How it works ──────────────────────────────────────────────────── #}
    <section class="section section--panel gp-steps">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.howItWorks.eyebrow }}</p>
            <h2>{{ content.howItWorks.title }}</h2>
            <p class="section-intro">{{ content.howItWorks.lead }}</p>
        </header>

        <ol class="gp-step-list">
            {% for step in content.howItWorks.steps %}
                <li class="gp-step-card surface-card">
                    <div class="gp-step-card__number" aria-hidden="true">{{ step.number }}</div>
                    <div class="gp-step-card__illustration" aria-hidden="true">
                        {% if step.illustration == 'phone-app' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <rect x="36" y="14" width="48" height="92" rx="8" fill="#ffffff" stroke="#003399" stroke-width="2.5"/>
                                <rect x="40" y="22" width="40" height="64" rx="3" fill="#f5f8fc"/>
                                <rect x="46" y="28" width="28" height="6" rx="2" fill="#4266b8"/>
                                <rect x="46" y="40" width="22" height="4" rx="1" fill="#4266b8" opacity="0.6"/>
                                <text x="60" y="68" font-family="Inter, sans-serif" font-size="20" font-weight="700" fill="#003399" text-anchor="middle">€</text>
                                <rect x="46" y="76" width="28" height="6" rx="3" fill="#ffcc00"/>
                                <circle cx="60" cy="96" r="3" fill="#003399"/>
                            </svg>
                        {% elseif step.illustration == 'payment-card' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <rect x="14" y="34" width="92" height="58" rx="6" fill="#003399"/>
                                <rect x="14" y="46" width="92" height="10" fill="#4266b8"/>
                                <rect x="22" y="64" width="18" height="14" rx="2" fill="#ffcc00"/>
                                <text x="96" y="84" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#ffffff" text-anchor="end">CDC</text>
                                <circle cx="88" cy="72" r="8" fill="none" stroke="#ffcc00" stroke-width="2"/>
                                <circle cx="80" cy="72" r="8" fill="none" stroke="#ffffff" stroke-width="2"/>
                            </svg>
                        {% elseif step.illustration == 'shopping' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="42" cy="38" r="10" fill="#003399"/>
                                <path d="M32 50 Q30 80 34 96 L50 96 Q54 80 52 50 Z" fill="#4266b8"/>
                                <path d="M52 56 Q62 58 72 64" stroke="#4266b8" stroke-width="5" fill="none" stroke-linecap="round"/>
                                <path d="M38 42 Q42 46 46 42" stroke="#ffffff" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                                <path d="M70 58 L94 58 L98 100 L66 100 Z" fill="#ffcc00"/>
                                <path d="M76 58 Q76 50 84 50 Q92 50 92 58" stroke="#003399" stroke-width="2" fill="none"/>
                                <text x="82" y="85" font-family="Inter, sans-serif" font-size="12" font-weight="700" fill="#003399" text-anchor="middle">€</text>
                            </svg>
                        {% endif %}
                    </div>
                    <div class="gp-step-card__copy">
                        <h3>{{ step.title }}</h3>
                        <p>{{ step.body }}</p>
                    </div>
                </li>
            {% endfor %}
        </ol>
    </section>

    {# ── 6. Work incentive ────────────────────────────────────────────────── #}
    <section class="section section--panel section--alt gp-incentive">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.workIncentive.eyebrow }}</p>
            <h2>{{ content.workIncentive.title }}</h2>
            <p class="section-intro">{{ content.workIncentive.lead }}</p>
        </header>

        {% if content.workIncentive.trampolineNote is defined %}
        <div class="gp-incentive__trampoline surface-card">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path d="M12 2 L15 9 L22 9.3 L17 14 L18.5 21 L12 17.5 L5.5 21 L7 14 L2 9.3 L9 9 Z" fill="#ffcc00" stroke="#003399" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            <p>{{ content.workIncentive.trampolineNote }}</p>
        </div>
        {% endif %}

        <figure class="gp-incentive-chart surface-card">
            <figcaption class="gp-incentive-chart__caption">{{ content.workIncentive.chart.caption }}</figcaption>

            <div class="gp-incentive-legend" aria-label="Légende du graphique">
                <div class="gp-incentive-legend__item">
                    <span class="gp-incentive-legend__swatch gp-incentive-legend__swatch--svg" aria-hidden="true"></span>
                    <span>Socle Vital Garanti (SVG)</span>
                </div>
                <div class="gp-incentive-legend__item">
                    <span class="gp-incentive-legend__swatch gp-incentive-legend__swatch--work" aria-hidden="true"></span>
                    <span>Revenu du travail</span>
                </div>
            </div>

            {% set maxTotal = content.workIncentive.chart.bars|reduce((m, b) => b.total > m ? b.total : m, 0) %}

            <div class="gp-incentive-chart__bars">
                {% for bar in content.workIncentive.chart.bars %}
                    <div class="gp-incentive-bar">
                        <div class="gp-incentive-bar__label">{{ bar.label }}</div>
                        <div class="gp-incentive-bar__track" style="width: {{ (bar.total / maxTotal * 100)|round }}%;">
                            {% for segment in bar.breakdown %}
                                <div class="gp-incentive-bar__segment gp-incentive-bar__segment--{{ segment.kind }}"
                                     style="flex: {{ segment.amount }};">
                                    <span>{{ segment.label }}</span>
                                    <strong>{{ segment.amount|number_format(0, ',', ' ') }} €</strong>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="gp-incentive-bar__total">{{ bar.total|number_format(0, ',', ' ') }} €/mois</div>
                    </div>
                {% endfor %}
            </div>

            <div class="gp-incentive-chart__gain">
                <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <path d="M4 12 L20 12 M14 6 L20 12 L14 18" stroke="#ffcc00" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="gp-incentive-chart__gain-label">{{ content.workIncentive.chart.gain.label }}</span>
                <strong>{{ content.workIncentive.chart.gain.value }}</strong>
            </div>
        </figure>

        <p class="gp-incentive__note">{{ content.workIncentive.note }}</p>
    </section>

    {# ── 7. Personas ──────────────────────────────────────────────────────── #}
    <section class="section section--panel gp-personas">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.personas.eyebrow }}</p>
            <h2>{{ content.personas.title }}</h2>
            <p class="section-intro">{{ content.personas.lead }}</p>
        </header>

        <div class="gp-persona-grid">
            {% for persona in content.personas.cards %}
                <article class="gp-persona-card surface-card">
                    <div class="gp-persona-card__avatar" aria-hidden="true">
                        {% if persona.illustration == 'persona-marie' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="60" cy="60" r="56" fill="#fff3b8"/>
                                <path d="M30 52 Q30 24 60 24 Q90 24 90 52 L90 70 Q88 56 82 54 L38 54 Q32 56 30 70 Z" fill="#003399"/>
                                <circle cx="60" cy="60" r="22" fill="#ffdcb8"/>
                                <circle cx="52" cy="60" r="2" fill="#003399"/>
                                <circle cx="68" cy="60" r="2" fill="#003399"/>
                                <path d="M52 70 Q60 75 68 70" stroke="#003399" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                                <circle cx="94" cy="88" r="8" fill="#ffcc00"/>
                                <path d="M88 94 Q87 108 90 116 L98 116 Q101 108 100 94 Z" fill="#ffcc00"/>
                            </svg>
                        {% elseif persona.illustration == 'persona-lucas' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="60" cy="60" r="56" fill="#e8eefc"/>
                                <path d="M38 48 Q38 30 60 30 Q82 30 82 48 L82 58 L38 58 Z" fill="#4266b8"/>
                                <circle cx="60" cy="62" r="22" fill="#ffdcb8"/>
                                <circle cx="52" cy="62" r="5" fill="none" stroke="#003399" stroke-width="1.8"/>
                                <circle cx="68" cy="62" r="5" fill="none" stroke="#003399" stroke-width="1.8"/>
                                <line x1="57" y1="62" x2="63" y2="62" stroke="#003399" stroke-width="1.8"/>
                                <path d="M52 74 Q60 78 68 74" stroke="#003399" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                                <rect x="86" y="86" width="16" height="12" fill="#ffcc00"/>
                                <line x1="94" y1="86" x2="94" y2="98" stroke="#ffffff" stroke-width="1"/>
                            </svg>
                        {% elseif persona.illustration == 'persona-fatima' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="60" cy="60" r="56" fill="#fff3b8"/>
                                <path d="M28 60 Q28 26 60 26 Q92 26 92 60 L92 90 Q88 78 78 76 L42 76 Q32 78 28 90 Z" fill="#4266b8"/>
                                <circle cx="60" cy="62" r="22" fill="#ffdcb8"/>
                                <circle cx="52" cy="62" r="2" fill="#003399"/>
                                <circle cx="68" cy="62" r="2" fill="#003399"/>
                                <path d="M52 72 Q60 76 68 72" stroke="#003399" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                            </svg>
                        {% elseif persona.illustration == 'persona-thomas' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="60" cy="60" r="56" fill="#e8eefc"/>
                                <path d="M36 48 Q36 32 60 32 Q84 32 84 48 L86 54 L34 54 Z" fill="#003399"/>
                                <rect x="50" y="54" width="20" height="4" rx="1" fill="#ffcc00"/>
                                <circle cx="60" cy="64" r="22" fill="#ffdcb8"/>
                                <circle cx="52" cy="64" r="2" fill="#003399"/>
                                <circle cx="68" cy="64" r="2" fill="#003399"/>
                                <path d="M52 74 Q60 78 68 74" stroke="#003399" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                            </svg>
                        {% endif %}
                    </div>
                    <div class="gp-persona-card__copy">
                        <h3>{{ persona.name }}</h3>
                        <p class="gp-persona-card__situation">{{ persona.situation }}</p>
                        {% if persona.svg_amount is defined %}
                        <p class="gp-persona-card__amount">Complément estimé : <strong>{{ persona.svg_amount }}</strong></p>
                        {% endif %}
                        <p class="gp-persona-card__body">{{ persona.body }}</p>
                    </div>
                </article>
            {% endfor %}
        </div>
    </section>

    {# ── 8. FAQ / Objections ──────────────────────────────────────────────── #}
    <section class="section section--panel section--alt gp-faq">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.faq.eyebrow }}</p>
            <h2>{{ content.faq.title }}</h2>
            <p class="section-intro">{{ content.faq.lead }}</p>
        </header>

        <div class="gp-faq__list">
            {% for item in content.faq.items %}
            <details class="gp-faq__item surface-card">
                <summary class="gp-faq__question">
                    <span class="gp-faq__q-icon" aria-hidden="true">?</span>
                    <span>{{ item.q }}</span>
                    <span class="gp-faq__chevron" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M6 9 L12 15 L18 9" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                </summary>
                <div class="gp-faq__answer">
                    <p>{{ item.a }}</p>
                </div>
            </details>
            {% endfor %}
        </div>
    </section>

    {# ── 9. Preserved rights ──────────────────────────────────────────────── #}
    <section class="section section--panel gp-shield">
        <div class="gp-shield__illustration" aria-hidden="true">
            <svg viewBox="0 0 180 200" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="gp-shield-grad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#4266b8"/>
                        <stop offset="100%" stop-color="#003399"/>
                    </linearGradient>
                </defs>
                <path d="M90 10 L170 40 L170 100 Q170 160 90 190 Q10 160 10 100 L10 40 Z" fill="url(#gp-shield-grad)"/>
                <path d="M90 22 L158 46 L158 100 Q158 150 90 178 Q22 150 22 100 L22 46 Z" fill="none" stroke="#ffffff" stroke-width="1" opacity="0.35"/>
                <path d="M54 100 L80 124 L130 72" stroke="#ffcc00" stroke-width="10" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <div class="gp-shield__copy">
            <p class="eyebrow">{{ content.preservedRights.eyebrow }}</p>
            <h2>{{ content.preservedRights.title }}</h2>
            <p class="section-intro">{{ content.preservedRights.lead }}</p>
            <ul class="gp-shield__list">
                {% for point in content.preservedRights.points %}
                    <li>
                        <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                            <circle cx="12" cy="12" r="11" fill="#ffcc00"/>
                            <path d="M7 12 L10.5 15.5 L17 9" stroke="#003399" stroke-width="2.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>{{ point.text }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </section>

    {# ── 10. Europe ───────────────────────────────────────────────────────── #}
    <section class="section section--panel section--alt gp-europe">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.europe.eyebrow }}</p>
            <h2>{{ content.europe.title }}</h2>
            <p class="section-intro">{{ content.europe.lead }}</p>
        </header>

        <div class="gp-europe__map" aria-hidden="true">
            <svg viewBox="0 0 560 360" xmlns="http://www.w3.org/2000/svg">
                <title>Carte stylisée de l'Union européenne avec capitales connectées</title>
                <path d="M170 135 L150 150 L118 146 L96 165 L112 198 L100 230 L126 258 L166 254 L194 276 L232 266 L250 292 L282 286 L272 252 L292 226 L326 238 L358 276 L392 268 L378 242 L408 222 L452 228 L476 202 L456 176 L470 144 L436 122 L390 126 L360 106 L326 118 L304 96 L316 60 L286 78 L266 112 L232 104 L206 122 Z"
                      fill="#e8eefc" stroke="#4266b8" stroke-width="1.5" opacity="0.9"/>
                <path d="M100 120 Q120 100 135 120 Q140 150 125 170 Q105 170 100 150 Z" fill="#e8eefc" stroke="#4266b8" stroke-width="1.5"/>
                <g stroke="#ffcc00" stroke-width="1.5" fill="none" stroke-dasharray="3 4" opacity="0.7">
                    <line x1="220" y1="180" x2="300" y2="160"/>
                    <line x1="300" y1="160" x2="360" y2="210"/>
                    <line x1="220" y1="180" x2="260" y2="240"/>
                    <line x1="260" y1="240" x2="360" y2="210"/>
                    <line x1="220" y1="180" x2="180" y2="130"/>
                    <line x1="300" y1="160" x2="340" y2="120"/>
                    <line x1="360" y1="210" x2="410" y2="170"/>
                    <line x1="260" y1="240" x2="320" y2="270"/>
                </g>
                {% set capitals = [
                    {x: 220, y: 180},
                    {x: 300, y: 160},
                    {x: 260, y: 240},
                    {x: 360, y: 210},
                    {x: 180, y: 130},
                    {x: 340, y: 120},
                    {x: 410, y: 170},
                    {x: 320, y: 270}
                ] %}
                {% for c in capitals %}
                    <g>
                        <circle cx="{{ c.x }}" cy="{{ c.y }}" r="8" fill="#ffcc00" opacity="0.25"/>
                        <circle cx="{{ c.x }}" cy="{{ c.y }}" r="4" fill="#ffcc00"/>
                    </g>
                {% endfor %}
            </svg>
        </div>

        <div class="gp-europe__pillars">
            {% for pillar in content.europe.pillars %}
                <article class="gp-europe-pillar surface-card">
                    <strong>{{ pillar.label }}</strong>
                    <p>{{ pillar.body }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    {# ── 11. Articles ─────────────────────────────────────────────────────── #}
    {% include 'page/civitalisme/_partials/_updates_feed.html.twig' with {
        eyebrow: 'Comprendre pas à pas',
        title: 'Articles et décryptages',
        lead: 'Des textes courts, des lectures commentées et des exemples pour rendre le Civitalisme concret, discutable et accessible.',
        updates: projectUpdates,
    } only %}

    {# ── 12. CTA ──────────────────────────────────────────────────────────── #}
    <section class="section section--panel gp-cta">
        <div class="gp-cta__copy">
            <p class="eyebrow">{{ content.cta.eyebrow }}</p>
            <h2>{{ content.cta.title }}</h2>
            <p class="section-intro">{{ content.cta.body }}</p>
            <div class="gp-cta__actions">
                {% for action in content.cta.actions %}
                    <a class="button {{ action.kind == 'ghost' ? 'button--ghost' : '' }}" href="{{ path(action.route) }}">
                        {{ action.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>

{% endblock %}
