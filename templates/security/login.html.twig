{% extends 'base.html.twig' %}

{% block title %}Connexion admin | Portfolio + Civitalisme{% endblock %}

{% block body %}
    <section class="section auth-section">
        <article class="surface-card auth-card">
            <p class="eyebrow">Back-office</p>
            <h1>Connexion administrateur</h1>
            <p class="auth-card__intro">Accès réservé à la gestion des contacts, des travaux et des blocs Civitalisme.</p>

            {% if error %}
                <div class="flash flash--error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form method="post" class="contact-form">
                <label for="username">E-mail</label>
                <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required>

                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" autocomplete="current-password" required>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="button" type="submit">Se connecter</button>
            </form>
        </article>
    </section>
{% endblock %}
