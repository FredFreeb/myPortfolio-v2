{% extends 'base.html.twig' %}

{% block title %}Portfolio | Portfolio + Civitalisme
{% endblock %}
{% block meta_description %}Portfolio de Fred : travaux, intention créative, stack Symfony et aperçu du projet Civitalisme.
{% endblock %}
{% block body_class %}theme-portfolio page-home
{% endblock %}

{% block body %}
	<section class="hero hero--home hero--immersive hero--spotlight hero--fullbleed" data-controller="parallax" data-parallax-intensity-value="16">
		<div class="hero-home__media" aria-hidden="true">
			<video class="hero-home__video" data-parallax-target="layer" data-parallax-depth="-0.45" autoplay muted loop playsinline preload="metadata" aria-label="Animation immersive d'un futur européen créatif">
				<source src="{{ asset('images/home/task_01knf9nff8fyfvjmb71z2h54hk_task_01knf9nff8fyfvjmb71z2h54hk_genid_8733ee21-cc40-462b-8f2f-11c74b0a2f81_26_04_05_17_06_871926_videos_00000_351871939_source.mp4') }}" type="video/mp4">
			</video>
			<div class="hero-home__veil"></div>
			<div class="hero-home__halo hero-home__halo--one" data-parallax-target="layer" data-parallax-depth="0.4"></div>
			<div class="hero-home__halo hero-home__halo--two" data-parallax-target="layer" data-parallax-depth="0.75"></div>
			<div class="hero-home__mesh"></div>
		</div>

		<div class="hero__copy">
			<p class="eyebrow hero__eyebrow-band">{{ 'home.hero.eyebrow'|trans }}</p>
			<h1 class="hero__title hero__title--glow hero__title--typed" data-controller="typewriter" data-typewriter-speed-value="34" data-typewriter-start-delay-value="280">
				{{ 'home.hero.title'|trans }}
			</h1>
			<p class="hero__lead">{{ 'home.hero.lead'|trans }}</p>

			<div class="hero__actions">
				<a class="button" href="{{ path('app_contact', {'_locale': app.request.locale}) }}">{{ 'home.hero.cta_contact'|trans }}</a>
				<a class="button button--ghost" href="{{ path('app_about', {'_locale': app.request.locale}) }}">{{ 'home.hero.cta_about'|trans }}</a>
			</div>

			<p class="hero-home__line">{{ 'home.hero.tagline'|trans }}</p>
		</div>
	</section>

	<section class="section section--panel section--panel-sun section--work-showcase">
		<div class="section-heading">
			<div>
				<p class="eyebrow">{{ 'home.works.eyebrow'|trans }}</p>
				<h2>{{ 'home.works.heading'|trans }}</h2>
			</div>
			<a class="section-link" href="{{ path('app_contact', {'_locale': app.request.locale}) }}">{{ 'home.works.cta'|trans }}</a>
		</div>

		<div class="card-grid card-grid--works">
			{% for work in featuredWorks %}
				<article class="work-card surface-card">
					<div class="work-card__cover {{ work.imagePath ? '' : 'work-card__cover--placeholder' }}">
						{% if work.imagePath %}
							<img src="{{ asset(work.imagePath) }}" alt="{{ work.title }}" loading="lazy" decoding="async">
						{% else %}
							<span>{{ work.title|slice(0, 2)|upper }}</span>
						{% endif %}
					</div>

					<div class="work-card__body">
                        <h3>{{ work.title }}</h3>
						<div class="meta-row">
							<span>{{ work.clientName ?: ('home.works.client_fallback'|trans) }}</span>
							{% if work.roleLabel %}
								<span>{{ work.roleLabel }}</span>
							{% endif %}
						</div>
                        <p class="work-card__excerpt">{{ work.excerpt }}</p>
						<div class="work-card__stack">
							<p class="stack-line">{{ work.stackSummary }}</p>
							{% if work.toolsUsed %}
								<p class="stack-line">{{ 'home.works.tools_label'|trans }} {{ work.toolsUsed }}</p>
							{% endif %}
						</div>
                    </div>

					<div class="work-card__actions">
						{% if work.projectUrl %}
							<a class="button button--ghost" href="{{ work.projectUrl }}" target="_blank" rel="noreferrer">{{ 'home.works.cta_view'|trans }}</a>
						{% endif %}
						{% if work.repositoryUrl %}
							<a class="button button--subtle" href="{{ work.repositoryUrl }}" target="_blank" rel="noreferrer">{{ 'home.works.cta_code'|trans }}</a>
						{% endif %}
					</div>
				</article>
			{% endfor %}
		</div>
	</section>

	<section class="section section--panel section--panel-mint">
		<div class="section-heading">
			<div>
				<p class="eyebrow">{{ 'home.civitalisme_section.eyebrow'|trans }}</p>
				<h2>{{ 'home.civitalisme_section.heading'|trans }}</h2>
			</div>
			<a class="section-link" href="{{ path('app_civitalisme') }}">{{ 'home.civitalisme_section.cta'|trans }}</a>
		</div>

		<div class="dual-grid">
			<article class="surface-card audience-card">
				<p class="panel-label">{{ 'home.civitalisme_section.public_label'|trans }}</p>
				<h3>{{ 'home.civitalisme_section.public_title'|trans }}</h3>
				<p>{{ 'home.civitalisme_section.public_desc'|trans }}</p>

				<div class="stacked-snippets">
					{% for update in publicHighlights %}
						<div class="snippet">
							<strong>{{ update.title }}</strong>
							<span>{{ update.summary }}</span>
						</div>
					{% endfor %}
				</div>

				<a class="button" href="{{ path('app_civitalisme') }}">{{ 'home.civitalisme_section.public_cta'|trans }}</a>
			</article>

			<article class="surface-card audience-card">
				<p class="panel-label">{{ 'home.civitalisme_section.institutional_label'|trans }}</p>
				<h3>{{ 'home.civitalisme_section.institutional_title'|trans }}</h3>
				<p>{{ 'home.civitalisme_section.institutional_desc'|trans }}</p>

				<div class="stacked-snippets">
					{% for update in institutionalHighlights %}
						<div class="snippet">
							<strong>{{ update.title }}</strong>
							<span>{{ update.summary }}</span>
						</div>
					{% endfor %}
				</div>

				<a class="button" href="{{ path('app_civitalisme_technical') }}">{{ 'home.civitalisme_section.institutional_cta'|trans }}</a>
			</article>
		</div>
    </section>

    {% if testimonials is not empty %}
        <section class="section section--panel section--panel-sun">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">{{ 'home.testimonials.eyebrow'|trans }}</p>
                    <h2>{{ 'home.testimonials.heading'|trans }}</h2>
                </div>
            </div>

            <div class="card-grid card-grid--compact">
                {% for testimonial in testimonials %}
                    <article class="surface-card narrative-card">
                        <p class="panel-label">{{ testimonial.companyName ?: ('home.testimonials.fallback'|trans) }}</p>
                        <h3>{{ testimonial.authorName }}</h3>
                        <p>"{{ testimonial.content }}"</p>
                        {% if testimonial.authorRole %}
                            <p class="stack-line">{{ testimonial.authorRole }}</p>
                        {% endif %}
                    </article>
                {% endfor %}
            </div>
        </section>
    {% endif %}

	<section class="section section--cta section--panel section--panel-sky">
		<div class="cta-band surface-card">
			<div>
				<p class="eyebrow">{{ 'home.cta.eyebrow'|trans }}</p>
				<h2>{{ 'home.cta.heading'|trans }}</h2>
				<p>{{ 'home.cta.body'|trans }}</p>
			</div>

                <div class="cta-band__actions">
                    <a class="button" href="{{ path('app_contact', {'_locale': app.request.locale}) }}">{{ 'home.cta.cta_write'|trans }}</a>
                    {% for link in contactLinks %}
                        {% if link.url %}
                            <a class="button button--ghost" href="{{ link.url }}" target="_blank" rel="noreferrer">{{ link.label }}</a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </section>
{% endblock %}
