{% extends 'base.html.twig' %}

{% block title %}Cadre institutionnel — Socle Vital Garanti européen | Civitalisme{% endblock %}
{% block meta_description %}Doctrine, architecture CDC, cadre juridique (art. 20 TUE), Charte SVG, modélisation du coût et feuille de route du Socle Vital Garanti européen — projet Civitalisme. Accès libre aux 8 rapports.{% endblock %}
{% block body_class %}theme-civitalisme page-civitalisme page-civitalisme--institution{% endblock %}

{% block extra_head %}
    {# Chart.js UMD — chargé avant les modules ES pour que window.Chart soit disponible #}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js" defer></script>

<style>
/* ── Schéma pédagogique V2 — cadre institutionnel ────────────────────────── */
.inst-ped-schema {
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 32px rgba(0,51,153,.1);
    overflow: hidden;
    margin: 0 auto 1.5rem;
    max-width: 900px;
}
.inst-ped-schema .ped-schema-header {
    padding: 1.25rem 2rem;
    background: #003399;
    display: flex; align-items: center; gap: 1rem;
}
.inst-ped-schema .ped-schema-header .ped-badge {
    width: 36px; height: 36px; border-radius: 50%;
    background: #ffcc00; color: #3a2800;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 900; flex-shrink: 0;
}
.inst-ped-schema .ped-schema-header h3 { font-size: 1.05rem; font-weight: 800; color: white; line-height: 1.2; }
.inst-ped-schema .ped-schema-header p  { font-size: .8rem; color: #96b0e8; margin-top: .15rem; }
.inst-ped-schema .ped-body { padding: 1.5rem 2rem 2rem; }
.inst-ped-schema .ped-zone {
    border-radius: 14px; padding: 1.25rem; margin-bottom: 1rem;
}
.inst-ped-schema .ped-zone-label {
    font-size: .68rem; font-weight: 800; letter-spacing: .14em; text-transform: uppercase;
    margin-bottom: .75rem; display: flex; align-items: center; gap: .4rem;
}
.inst-ped-schema .ped-zone-label::after {
    content: ''; flex: 1; height: 1px; background: currentColor; opacity: .25;
}
.inst-ped-schema .ped-nodes { display: flex; gap: .75rem; flex-wrap: wrap; align-items: stretch; }
.inst-ped-schema .ped-node {
    flex: 1; min-width: 150px; border-radius: 12px; padding: 1rem;
    display: flex; flex-direction: column; gap: .3rem;
}
.inst-ped-schema .ped-node-icon { font-size: 1.6rem; line-height: 1; margin-bottom: .25rem; }
.inst-ped-schema .ped-node-title { font-size: .95rem; font-weight: 800; line-height: 1.2; }
.inst-ped-schema .ped-node-sub  { font-size: .78rem; opacity: .8; line-height: 1.35; }
.inst-ped-schema .ped-node-tag  {
    display: inline-block; padding: .15rem .5rem; border-radius: 20px;
    font-size: .7rem; font-weight: 700; margin-top: .3rem; width: fit-content;
}
.inst-ped-schema .ped-arrow-row {
    display: flex; align-items: center; justify-content: center; gap: .5rem; margin: .6rem 0;
}
.inst-ped-schema .ped-arrow-down { display: flex; flex-direction: column; align-items: center; gap: .15rem; }
.inst-ped-schema .ped-arrow-line { width: 2px; height: 28px; border-radius: 2px; }
.inst-ped-schema .ped-arrow-head { width: 0; height: 0; border-left: 7px solid transparent; border-right: 7px solid transparent; }
.inst-ped-schema .ped-arrow-label {
    font-size: .78rem; font-weight: 600; padding: .2rem .7rem; border-radius: 20px; white-space: nowrap;
}
.inst-ped-schema .ped-rails { display: grid; grid-template-columns: 1fr 36px 1fr; align-items: center; }
.inst-ped-schema .ped-rail { border-radius: 12px; padding: 1rem; }
.inst-ped-schema .ped-rail-divider {
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; font-weight: 900; color: #c0392b;
}
.inst-ped-schema .ped-points { display: flex; flex-direction: column; gap: .4rem; margin-top: .5rem; }
.inst-ped-schema .ped-point { display: flex; align-items: flex-start; gap: .5rem; font-size: .8rem; line-height: 1.35; }
.inst-ped-schema .ped-dot {
    width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem; font-weight: 900; margin-top: 1px; color: white;
}
.inst-ped-schema .ped-steps {
    display: flex; align-items: flex-start; position: relative; margin-bottom: 1.25rem;
}
.inst-ped-schema .ped-step {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    text-align: center; gap: .4rem; position: relative; padding: 0 .25rem;
}
.inst-ped-schema .ped-step::after {
    content: ''; position: absolute; top: 18px; left: 55%; width: 90%; height: 2px;
    background: #003399; opacity: .2; z-index: 0;
}
.inst-ped-schema .ped-step:last-child::after { display: none; }
.inst-ped-schema .ped-step-num {
    width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center;
    justify-content: center; font-size: .9rem; font-weight: 900; color: white;
    z-index: 1; position: relative; flex-shrink: 0;
}
.inst-ped-schema .ped-step-label { font-size: .75rem; font-weight: 700; color: #003399; line-height: 1.3; }
.inst-ped-schema .ped-step-sub   { font-size: .7rem; color: #6b7280; line-height: 1.3; }
.inst-ped-schema .ped-callout {
    border-radius: 12px; padding: 1rem 1.25rem; font-size: .82rem; line-height: 1.5;
    display: flex; gap: .75rem; align-items: flex-start; margin-top: .75rem;
}
.inst-ped-schema .ped-callout-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: .05rem; }
.inst-ped-schema .ped-pills { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .4rem; }
.inst-ped-schema .ped-pill { background: #003399; color: white; padding: .2rem .6rem; border-radius: 20px; font-size: .73rem; font-weight: 600; }
.inst-ped-schema .ped-formula {
    background: white; border: 2px solid #003399; border-radius: 12px;
    padding: 1rem 1.25rem; margin-top: 1rem;
}
.inst-ped-schema .ped-formula-title {
    font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase;
    color: #003399; margin-bottom: .5rem;
}
.inst-ped-schema .ped-formula-eq {
    font-family: 'IBM Plex Mono', 'Courier New', monospace;
    font-size: .85rem; color: #003399; font-weight: 700;
    background: #e8eefc; border-radius: 8px; padding: .5rem .9rem;
    margin-bottom: .4rem; line-height: 1.5;
}
.inst-ped-schema .ped-formula-note { font-size: .78rem; color: #6b7280; line-height: 1.4; }
/* Couleurs utilitaires */
.inst-ped-schema .bg-navy     { background: #003399; color: white; }
.inst-ped-schema .bg-navy-lt  { background: #e8eefc; color: #003399; }
.inst-ped-schema .bg-gold     { background: #ffcc00; color: #3a2800; }
.inst-ped-schema .bg-gold-soft{ background: #fff9e0; color: #6b4c00; }
.inst-ped-schema .bg-green    { background: #1a7a5e; color: white; }
.inst-ped-schema .bg-green-lt { background: #e6f5ef; color: #1a7a5e; }
.inst-ped-schema .bg-grey-lt  { background: #f3f4f6; color: #6b7280; }
.inst-ped-schema .bg-white    { background: white; }
.inst-ped-schema .c-navy  { color: #003399; }
.inst-ped-schema .c-gold  { color: #b38a00; }
.inst-ped-schema .c-green { color: #1a7a5e; }
.inst-ped-schema .c-grey  { color: #6b7280; }
.inst-ped-schema .b-navy  { border: 2px solid #003399; }
.inst-ped-schema .b-gold  { border: 2px solid #ffcc00; }
.inst-ped-schema .b-green { border: 2px solid #1a7a5e; }
.inst-ped-schema .b-grey  { border: 1.5px solid #d1d5db; }
.inst-ped-schema .b-dashed{ border-style: dashed !important; }
/* Dark mode */
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema {
    background: rgba(10, 25, 70, 0.75);
    box-shadow: 0 4px 32px rgba(0,0,0,.4);
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-zone.bg-navy-lt  { background: rgba(0,51,153,.2); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-zone.bg-gold-soft { background: rgba(255,204,0,.08); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-zone.bg-grey-lt  { background: rgba(255,255,255,.05); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-zone.bg-green-lt { background: rgba(26,122,94,.12); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-node.bg-white     { background: rgba(255,255,255,.07); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-rail.bg-grey-lt   { background: rgba(255,255,255,.05); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-formula           { background: rgba(10,25,70,.6); }
html[data-color-scheme="dark"] body.theme-civitalisme .inst-ped-schema .ped-formula-eq        { background: rgba(0,51,153,.3); color: #c8d8ff; }
@media (max-width: 640px) {
    .inst-ped-schema .ped-rails  { grid-template-columns: 1fr; gap: .5rem; }
    .inst-ped-schema .ped-rail-divider { display: none; }
    .inst-ped-schema .ped-steps  { flex-wrap: wrap; gap: .75rem; }
    .inst-ped-schema .ped-step::after { display: none; }
    .inst-ped-schema .ped-body   { padding: 1rem; }
}

/* ── Dark mode — inst-risks ──────────────────────────────────────────────── */
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risks__title {
    color: var(--text);
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk {
    background: rgba(10, 25, 70, 0.65);
    border-color: rgba(100, 160, 255, 0.18);
    box-shadow: 0 4px 20px rgba(0,0,0,.35);
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk--faible {
    background: linear-gradient(160deg, rgba(10, 25, 70, 0.70), rgba(66, 102, 184, 0.18));
    border-left-color: #4266b8;
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk--moyen {
    background: linear-gradient(160deg, rgba(10, 25, 70, 0.70), rgba(255, 204, 0, 0.12));
    border-left-color: #ffcc00;
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk--élevé,
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk--eleve {
    background: linear-gradient(160deg, rgba(10, 25, 70, 0.70), rgba(192, 57, 43, 0.14));
    border-left-color: #e74c3c;
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk__level {
    color: var(--muted);
}
html[data-color-scheme="dark"] body.theme-civitalisme .inst-risk h4 {
    color: var(--text);
}
</style>
{% endblock %}

{% block body %}
    {# =============================================================
       1. HERO INSTITUTIONNEL
       ============================================================= #}
    <section class="inst-hero">
        <div class="inst-hero__content">
            <p class="inst-hero__eyebrow">
                <svg viewBox="0 0 60 40" width="28" height="19" aria-hidden="true" focusable="false">
                    <rect width="60" height="40" fill="#003399"/>
                    <g fill="#ffcc00">
                        <circle cx="30" cy="8" r="1.8"/>
                        <circle cx="36" cy="9.6" r="1.8"/>
                        <circle cx="40.39" cy="14" r="1.8"/>
                        <circle cx="42" cy="20" r="1.8"/>
                        <circle cx="40.39" cy="26" r="1.8"/>
                        <circle cx="36" cy="30.4" r="1.8"/>
                        <circle cx="30" cy="32" r="1.8"/>
                        <circle cx="24" cy="30.4" r="1.8"/>
                        <circle cx="19.61" cy="26" r="1.8"/>
                        <circle cx="18" cy="20" r="1.8"/>
                        <circle cx="19.61" cy="14" r="1.8"/>
                        <circle cx="24" cy="9.6" r="1.8"/>
                    </g>
                </svg>
                <span>{{ content.hero.eyebrow }}</span>
            </p>
            <h1 class="inst-hero__title">{{ content.hero.title }}</h1>
            <p class="inst-hero__subtitle">{{ content.hero.subtitle }}</p>
            <p class="inst-hero__lead">{{ content.hero.lead }}</p>

            <ul class="inst-hero__highlights">
                {% for item in content.hero.highlights %}
                    <li>
                        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
                            <path d="M5 12.5 L10 17.5 L19 7" fill="none" stroke="#ffcc00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>{{ item }}</span>
                    </li>
                {% endfor %}
            </ul>

            <div class="inst-hero__actions">
                <a class="button" href="#telechargements">Télécharger les rapports</a>
                <a class="button button--ghost" href="{{ path('app_civitalisme') }}">Version grand public</a>
            </div>
        </div>

        <aside class="inst-hero__panel">
            <p class="inst-hero__panel-label">Document de travail ouvert</p>
            <p class="inst-hero__panel-body">
                Le Civitalisme publie l’intégralité de sa doctrine en accès libre.
                Chaque rapport peut être cité, annoté, critiqué et amendé.
            </p>
            <dl class="inst-hero__meta">
                <div><dt>Version</dt><dd>v1 · {{ "now"|date("Y") }}</dd></div>
                <div><dt>Rapports</dt><dd>8 documents thématiques</dd></div>
                <div><dt>Hébergement</dt><dd>Europe</dd></div>
                <div><dt>Licence</dt><dd>Lecture libre, citation autorisée</dd></div>
            </dl>
        </aside>
    </section>

    {% include 'page/civitalisme/_partials/_page_switch.html.twig' with {
        active: 'technical',
        title: 'Navigation Civitalisme',
        description: 'Cette page technique approfondit la doctrine, l’architecture, le droit et la feuille de route. La version grand public reste disponible pour une lecture plus synthétique.',
    } only %}

    {# =============================================================
       2. SYNTHÈSE EXÉCUTIVE + TABLE DES RAPPORTS
       ============================================================= #}
    <section class="inst-section">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.executive.eyebrow }}</p>
            <h2>{{ content.executive.title }}</h2>
            <p class="inst-section__lead">{{ content.executive.lead }}</p>
        </header>

        <div class="inst-pillars">
            {% for pillar in content.executive.pillars %}
                <article class="inst-pillar">
                    <div class="inst-pillar__number">{{ loop.index }}</div>
                    <h3>{{ pillar.title }}</h3>
                    <p>{{ pillar.body }}</p>
                </article>
            {% endfor %}
        </div>

        <div class="inst-reports">
            <div class="inst-reports__header">
                <h3>Les {{ content.executive.reports|length }} rapports thématiques</h3>
                <p>Téléchargement libre, PDF européen.</p>
            </div>
            <ul class="inst-reports__list">
                {% for report in content.executive.reports %}
                    <li class="inst-report">
                        <div class="inst-report__index">{{ report.index }}</div>
                        <div class="inst-report__body">
                            <p class="inst-report__theme">{{ report.theme }}</p>
                            <h4>{{ report.title }}</h4>
                            <p>{{ report.body }}</p>
                        </div>
                        <a class="inst-report__link" href="{{ report.href }}" download>
                            <span>PDF</span>
                            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                <path d="M12 3 V16 M6 10 L12 16 L18 10 M4 20 H20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </section>

    {# =============================================================
       3. DOCTRINE — DOUBLE CIRCUIT MONÉTAIRE
       ============================================================= #}
    <section class="inst-section inst-section--alt">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.doctrine.eyebrow }}</p>
            <h2>{{ content.doctrine.title }}</h2>
            <p class="inst-section__lead">{{ content.doctrine.lead }}</p>
        </header>

        <div class="inst-circuit">
            <div class="inst-circuit__column inst-circuit__column--euro">
                <p class="inst-circuit__badge">Euro classique</p>
                <h3>Sphère de progression</h3>
                <p class="inst-circuit__scope">Marché général · épargne · investissement · entrepreneuriat · salaires · luxe.</p>
                <ul>
                    <li>Fonctionne exactement comme aujourd’hui.</li>
                    <li>Aucune atteinte à la liberté économique.</li>
                    <li>Régulation actuelle maintenue (BCE, DORA, MiCA, CRR/CRD).</li>
                </ul>
            </div>
            <div class="inst-circuit__divider" aria-hidden="true">
                <svg viewBox="0 0 80 200" width="80" height="200">
                    <defs>
                        <linearGradient id="inst-divider" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#003399" stop-opacity="0.4"/>
                            <stop offset="50%" stop-color="#ffcc00" stop-opacity="0.9"/>
                            <stop offset="100%" stop-color="#003399" stop-opacity="0.4"/>
                        </linearGradient>
                    </defs>
                    <rect x="37" y="0" width="6" height="200" fill="url(#inst-divider)" rx="3"/>
                    <circle cx="40" cy="100" r="22" fill="#ffcc00"/>
                    <text x="40" y="106" text-anchor="middle" font-family="Inter, sans-serif" font-weight="700" font-size="14" fill="#003399">⇄</text>
                </svg>
            </div>
            <div class="inst-circuit__column inst-circuit__column--euroe">
                <p class="inst-circuit__badge inst-circuit__badge--accent">CDC</p>
                <h3>Sphère vitale</h3>
                <p class="inst-circuit__scope">Logement · alimentation · énergie · transport · santé · éducation.</p>
                <ul>
                    <li>Permissionné, auditable, non thésaurisable.</li>
                    <li>Convertible en euro uniquement par commerçants agréés.</li>
                    <li>Volume et périmètre encadrés par la BCE et le Parlement.</li>
                </ul>
            </div>
        </div>

        <div class="inst-table-wrapper">
            <table class="inst-table">
                <thead>
                    <tr>
                        <th scope="col">Instrument</th>
                        {% for column in content.doctrine.table.columns %}
                            <th scope="col">{{ column.label }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in content.doctrine.table.rows %}
                        <tr>
                            <th scope="row">{{ row.instrument }}</th>
                            {% for column in content.doctrine.table.columns %}
                                <td>{{ row[column.key] }}</td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    {# =============================================================
       4. ARCHITECTURE TECHNIQUE EUROE
       ============================================================= #}
    <section class="inst-section">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.architecture.eyebrow }}</p>
            <h2>{{ content.architecture.title }}</h2>
            <p class="inst-section__lead">{{ content.architecture.lead }}</p>
        </header>

        <div class="inst-layers" role="list">
            {% for layer in content.architecture.layers %}
                <article class="inst-layer" role="listitem">
                    <div class="inst-layer__index">{{ layer.index }}</div>
                    <div class="inst-layer__body">
                        <h3>{{ layer.title }}</h3>
                        <p>{{ layer.body }}</p>
                    </div>
                </article>
            {% endfor %}
        </div>

        <h3 class="inst-lifecycle__title">Cycle de vie d’un EuroE</h3>
        <ol class="inst-lifecycle">
            {% for step in content.architecture.lifecycle %}
                <li class="inst-lifecycle__step">
                    <div class="inst-lifecycle__circle">{{ step.step }}</div>
                    <div class="inst-lifecycle__body">
                        <h4>{{ step.title }}</h4>
                        <p>{{ step.body }}</p>
                    </div>
                    {% if not loop.last %}
                        <svg class="inst-lifecycle__arrow" viewBox="0 0 40 16" width="40" height="16" aria-hidden="true" focusable="false">
                            <path d="M2 8 H34 M28 2 L34 8 L28 14" fill="none" stroke="#003399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    </section>


    {# =============================================================
       4b. SCHÉMA DE FONCTIONNEMENT DU SVG — CIRCUIT CDC
       ============================================================= #}
    <section class="inst-section" id="schema-svg">
        <header class="inst-section__heading">
            <p class="eyebrow">Schéma de fonctionnement</p>
            <h2>Comment le SVG fonctionne, en un coup d'œil</h2>
            <p class="inst-section__lead">Le circuit CDC en 5 étapes — de l'émission à la contrepartie économique.</p>
        </header>

        <div class="inst-ped-schema">
            <div class="ped-schema-header">
                <div class="ped-badge">⚙</div>
                <div>
                    <h3>Circuit CDC — de la supervision à la boucle fiscale</h3>
                    <p>5 étapes : BCE supervise → banque génère → réseau européen → prestataire agréé → TVA collectée</p>
                </div>
            </div>
            <div class="ped-body">

                {# Étapes horizontales #}
                <div class="ped-steps">
                    <div class="ped-step">
                        <div class="ped-step-num" style="background:#003399">🏛</div>
                        <div class="ped-step-label">① BCE</div>
                        <div class="ped-step-sub">Supervise · Fixe le panier vital (LW₀)</div>
                    </div>
                    <div class="ped-step">
                        <div class="ped-step-num" style="background:#b38a00">🏦</div>
                        <div class="ped-step-label">② Banque</div>
                        <div class="ped-step-sub">Calcule · Crédite le CDC mensuel</div>
                    </div>
                    <div class="ped-step">
                        <div class="ped-step-num" style="background:#003399">🇪🇺</div>
                        <div class="ped-step-label">③ Réseau TIPS</div>
                        <div class="ped-step-sub">Paiement via infrastructure BCE</div>
                    </div>
                    <div class="ped-step">
                        <div class="ped-step-num" style="background:#1a7a5e">🏪</div>
                        <div class="ped-step-label">④ Prestataire</div>
                        <div class="ped-step-sub">Agréé Charte SVG · Réglé en €</div>
                    </div>
                    <div class="ped-step">
                        <div class="ped-step-num" style="background:#b38a00">📋</div>
                        <div class="ped-step-label">⑤ TVA + retour</div>
                        <div class="ped-step-sub">~20 % → Trésor · CDC annulé</div>
                    </div>
                </div>

                {# Zone supervision #}
                <div class="ped-zone bg-navy-lt b-navy">
                    <div class="ped-zone-label c-navy">🏛 Supervision — Banque Centrale Européenne (BCE)</div>
                    <div class="ped-nodes">
                        <div class="ped-node bg-navy" style="flex:2">
                            <div class="ped-node-icon">🏛</div>
                            <div class="ped-node-title">La BCE supervise</div>
                            <div class="ped-node-sub">Elle ne verse pas directement — elle fixe les règles du mécanisme et audite les opérateurs.</div>
                            <div class="ped-node-tag bg-gold">Art. 20 TUE · coopération renforcée</div>
                        </div>
                        <div class="ped-node bg-navy-lt b-navy" style="flex:3">
                            <div class="ped-node-icon">📐</div>
                            <div class="ped-node-title c-navy">Paramètres BCE</div>
                            <div class="ped-points">
                                <div class="ped-point"><div class="ped-dot bg-navy">1</div><span><strong>LW₀ = 1 650 € calibré Eurostat 2024</strong> — panier vital de référence UE</span></div>
                                <div class="ped-point"><div class="ped-dot bg-navy">2</div><span>Coefficient <strong>Zone × HICP × Eq</strong> — ajustement géographique et familial</span></div>
                                <div class="ped-point"><div class="ped-dot bg-navy">3</div><span>Masse totale de CDC autorisée en circulation (plafond macro)</span></div>
                                <div class="ped-point"><div class="ped-dot bg-navy">4</div><span>Audit des banques opératrices certifiées · Charte SVG</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#003399"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #003399"></div>
                    </div>
                    <div class="ped-arrow-label bg-navy-lt c-navy">Paramètres transmis aux banques certifiées</div>
                </div>

                {# Zone génération #}
                <div class="ped-zone bg-gold-soft b-gold">
                    <div class="ped-zone-label c-gold">🏦 Génération CDC — Banques commerciales certifiées</div>
                    <div class="ped-nodes">
                        <div class="ped-node bg-gold">
                            <div class="ped-node-icon">🏦</div>
                            <div class="ped-node-title">Calcul automatique</div>
                            <div class="ped-node-sub">Chaque 1ᵉʳ du mois, la banque applique la formule pour chaque foyer éligible domicilié.</div>
                            <div class="ped-node-tag bg-navy" style="color:white">Opérateur certifié BCE</div>
                        </div>
                        <div class="ped-node bg-white b-gold" style="flex:2;background:white;border:2px solid #ffcc00">
                            <div class="ped-node-title c-navy" style="margin-bottom:.4rem">🧮 Formule SVG</div>
                            <div class="ped-formula" style="margin-top:0;border:none;padding:.5rem .75rem;background:#e8eefc;border-radius:8px">
                                <div class="ped-formula-eq" style="background:white;border:1.5px solid #003399">SVG = max{0 ; LW₀ × Eq × Zone × HICP − [Pension + max(0 ; Revenu − 300×n)]}</div>
                            </div>
                            <div class="ped-node-sub c-grey" style="margin-top:.4rem">Résultat positif → crédité sur le compte CDC. Résultat nul ou négatif → rien versé. France : ~1 350 €/mois pour une personne seule.</div>
                        </div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#b38a00"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #b38a00"></div>
                    </div>
                    <div class="ped-arrow-label bg-gold-soft c-gold">Crédit sur réseau européen souverain</div>
                </div>

                {# Zone rails #}
                <div class="ped-zone bg-grey-lt b-grey" style="padding:.75rem">
                    <div class="ped-zone-label c-grey">⚡ Infrastructure de paiement — deux réseaux parallèles et indépendants</div>
                    <div class="ped-rails">
                        <div class="ped-rail bg-grey-lt b-grey b-dashed">
                            <div class="ped-node-icon" style="font-size:1.2rem">💳</div>
                            <div style="font-size:.85rem;font-weight:800;color:#6b7280;margin:.25rem 0">Visa / Mastercard</div>
                            <div style="font-size:.75rem;color:#6b7280;line-height:1.4">Réseau privé — vos euros classiques. <strong>Inchangé, non concerné par le SVG.</strong></div>
                        </div>
                        <div class="ped-rail-divider">≠</div>
                        <div class="ped-rail bg-navy-lt b-navy">
                            <div class="ped-node-icon" style="font-size:1.2rem">🇪🇺</div>
                            <div style="font-size:.85rem;font-weight:800;color:#003399;margin:.25rem 0">TIPS · TARGET2 · Wero</div>
                            <div style="font-size:.75rem;color:#003399;line-height:1.4">Infrastructure publique BCE. <strong>Souveraineté européenne garantie · Aucun acteur privé non-UE.</strong></div>
                            <div style="margin-top:.5rem;padding:.3rem .6rem;background:#003399;border-radius:6px;font-size:.72rem;color:#ffcc00;font-weight:700">Compte CDC — dépenses vitales uniquement · Ni retrait cash · Ni accumulation</div>
                        </div>
                    </div>
                </div>

                <div class="ped-arrow-row">
                    <div class="ped-arrow-down">
                        <div class="ped-arrow-line" style="background:#003399"></div>
                        <div class="ped-arrow-head" style="border-top:10px solid #003399"></div>
                    </div>
                    <div class="ped-arrow-label bg-navy" style="color:#ffcc00">Paiement CDC chez un prestataire agréé Charte SVG</div>
                </div>

                {# Zone prestataire + TVA #}
                <div class="ped-nodes" style="margin-bottom:1rem">
                    <div class="ped-node bg-green" style="flex:1">
                        <div class="ped-node-icon">🏪</div>
                        <div class="ped-node-title">Prestataire agréé</div>
                        <div class="ped-node-sub">Reçoit le CDC · Réglé en € classique via sa banque (TARGET2 / SEPA). La Charte SVG garantit l'appartenance au périmètre vital.</div>
                        <div class="ped-pills" style="margin-top:.5rem">
                            <span class="ped-pill">🏠 Loyer</span>
                            <span class="ped-pill">🥦 Alimentation</span>
                            <span class="ped-pill">⚡ Énergie</span>
                            <span class="ped-pill">🚌 Transport</span>
                            <span class="ped-pill">🏥 Santé</span>
                            <span class="ped-pill">📚 Éducation</span>
                        </div>
                    </div>
                    <div class="ped-node bg-gold-soft b-gold" style="flex:1">
                        <div class="ped-node-icon">📋</div>
                        <div class="ped-node-title c-gold">TVA ≈ 20 % générée</div>
                        <div class="ped-node-sub" style="color:#6b4c00">Chaque transaction CDC génère de la TVA → Trésor public → réduit le coût net du dispositif.</div>
                        <div style="margin-top:.6rem;padding:.4rem .7rem;background:#ffcc00;border-radius:8px;font-size:.75rem;font-weight:800;color:#3a2800">
                            🔄 CDC annulé au règlement — pas d'accumulation, pas de marché secondaire
                        </div>
                    </div>
                </div>

                <div class="ped-callout bg-navy-lt">
                    <div class="ped-callout-icon">📌</div>
                    <div><strong>Lecture synthétique :</strong> ① La BCE fixe le panier vital (LW₀) et supervise. ② La banque calcule et crédite le CDC mensuel selon la formule. ③ Le citoyen dépense via réseau TIPS/Wero. ④ Le prestataire est réglé en euros classiques. ⑤ Le CDC est annulé au règlement — la TVA générée retourne à la collectivité, réduisant le coût net du dispositif.</div>
                </div>

            </div>
        </div>
    </section>

    {# =============================================================
       5. FORMULE SVG
       ============================================================= #}
    <section class="inst-section inst-section--alt">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.formula.eyebrow }}</p>
            <h2>{{ content.formula.title }}</h2>
            <p class="inst-section__lead">{{ content.formula.lead }}</p>
        </header>

        <div class="inst-formula">
            <p class="inst-formula__equation">{{ content.formula.equation }}</p>
        </div>

        <div class="inst-formula-grid">
            <div class="inst-formula-grid__params">
                <h3>Paramètres</h3>
                <ul>
                    {% for param in content.formula.parameters %}
                        <li>
                            <span class="inst-formula-grid__symbol">{{ param.symbol }}</span>
                            <span class="inst-formula-grid__label">{{ param.label }}</span>
                            <span class="inst-formula-grid__value">{{ param.value }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </div>
            <div class="inst-formula-grid__principles">
                <h3>Principes</h3>
                <ul>
                    {% for principle in content.formula.principles %}
                        <li>
                            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
                                <path d="M5 12.5 L10 17.5 L19 7" fill="none" stroke="#003399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span>{{ principle }}</span>
                        </li>
                    {% endfor %}
                </ul>
                <p class="inst-formula-grid__hint">
                    Testez la formule ci-dessous avec votre propre situation de foyer.
                </p>
            </div>
        </div>
    </section>

    {# =============================================================
       5b. SIMULATEUR INTERACTIF
       ============================================================= #}
    <section class="inst-section inst-simulator"
             data-controller="svg-simulator"
             id="simulateur-svg"
             aria-label="Simulateur interactif du Socle Vital Garanti">
        <header class="inst-section__heading">
            <p class="eyebrow">Simulateur interactif</p>
            <h2>Calculez votre SVG en temps réel</h2>
            <p class="inst-section__lead">
                Ajustez la composition de votre foyer, la zone géographique et vos revenus.
                Le montant se recalcule instantanément selon la formule officielle.
            </p>
        </header>

        <div class="sim-layout">
            {# ---- Colonne gauche : contrôles ---- #}
            <div class="sim-controls">
                <div class="sim-group">
                    <label class="sim-label" for="sim-adults">Adultes dans le foyer</label>
                    <div class="sim-stepper">
                        <button type="button" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('input', {bubbles:true}))">−</button>
                        <input id="sim-adults" type="number" min="1" max="4" value="1"
                               data-svg-simulator-target="adults"
                               data-action="input->svg-simulator#compute">
                        <button type="button" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('input', {bubbles:true}))">+</button>
                    </div>
                </div>

                <div class="sim-group">
                    <label class="sim-label" for="sim-children">Enfants à charge</label>
                    <div class="sim-stepper">
                        <button type="button" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('input', {bubbles:true}))">−</button>
                        <input id="sim-children" type="number" min="0" max="6" value="0"
                               data-svg-simulator-target="children"
                               data-action="input->svg-simulator#compute">
                        <button type="button" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('input', {bubbles:true}))">+</button>
                    </div>
                </div>

                <div class="sim-group">
                    <label class="sim-label" for="sim-zone">Zone géographique</label>
                    <select id="sim-zone" class="sim-select"
                            data-svg-simulator-target="zone"
                            data-action="change->svg-simulator#compute">
                        <option value="expensive">Zone chère (Paris, Munich, Amsterdam…) +15 %</option>
                        <option value="median" selected>Zone médiane</option>
                        <option value="cheap">Zone basse (régions rurales, Europe centrale) −10 %</option>
                    </select>
                </div>

                <div class="sim-group">
                    <label class="sim-label" for="sim-year">Année de référence</label>
                    <select id="sim-year" class="sim-select"
                            data-svg-simulator-target="year"
                            data-action="change->svg-simulator#compute">
                        <option value="2026" selected>2026 (base)</option>
                        <option value="2027">2027 (+2,1 %)</option>
                        <option value="2028">2028 (+4,2 %)</option>
                        <option value="2029">2029 (+6,4 %)</option>
                        <option value="2030">2030 (+8,6 %)</option>
                    </select>
                </div>

                <hr class="sim-divider">

                <div class="sim-group">
                    <label class="sim-label" for="sim-pension">Pensions du foyer (€/mois)</label>
                    <p class="sim-hint">Retraites et pensions actuelles — elles sont préservées et simplement déduites.</p>
                    <input id="sim-pension" type="range" min="0" max="3000" step="50" value="0"
                           class="sim-range"
                           data-svg-simulator-target="pension"
                           data-action="input->svg-simulator#compute">
                    <output class="sim-range-value" for="sim-pension"
                            data-svg-simulator-target="pensionOutput">0 €</output>
                </div>

                <div class="sim-group">
                    <label class="sim-label" for="sim-active-income">Revenus d'activité du foyer (€/mois)</label>
                    <p class="sim-hint">Salaires nets. Franchise de 300 €/actif non déduite.</p>
                    <input id="sim-active-income" type="range" min="0" max="4000" step="50" value="0"
                           class="sim-range"
                           data-svg-simulator-target="activeIncome"
                           data-action="input->svg-simulator#compute">
                    <output class="sim-range-value" for="sim-active-income"
                            data-svg-simulator-target="activeIncomeOutput">0 €</output>
                </div>

                <div class="sim-group">
                    <label class="sim-label" for="sim-active-workers">Nombre d'actifs dans le foyer</label>
                    <div class="sim-stepper">
                        <button type="button" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('input', {bubbles:true}))">−</button>
                        <input id="sim-active-workers" type="number" min="0" max="4" value="0"
                               data-svg-simulator-target="activeWorkers"
                               data-action="input->svg-simulator#compute">
                        <button type="button" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('input', {bubbles:true}))">+</button>
                    </div>
                </div>
            </div>

            {# ---- Colonne droite : résultat ---- #}
            <div class="sim-result-panel">
                <div class="sim-result">
                    <p class="sim-result__label">SVG mensuel estimé</p>
                    <p class="sim-result__amount" data-svg-simulator-target="result">1 650 €</p>
                    <p class="sim-result__unit">CDC / mois</p>
                    <div class="sim-result__total-row">
                        <span>Revenu total du foyer</span>
                        <strong data-svg-simulator-target="totalResult">1 650 €</strong>
                    </div>
                </div>

                <div class="sim-bar-legend">
                    <span class="sim-bar-legend__item sim-bar-legend__item--svg">SVG (CDC)</span>
                    <span class="sim-bar-legend__item sim-bar-legend__item--franch">Franchise travail</span>
                    <span class="sim-bar-legend__item sim-bar-legend__item--work">Revenu actif net</span>
                </div>
                <div class="sim-bar-wrapper" aria-hidden="true">
                    <div class="sim-bar" data-svg-simulator-target="bar"></div>
                </div>

                <div class="sim-breakdown" data-svg-simulator-target="breakdown"></div>

                <p class="sim-disclaimer">
                    Ce simulateur est indicatif. Les montants réels dépendent des paramètres finaux
                    adoptés par le Parlement européen. Les retraites existantes ne sont jamais supprimées.
                </p>
            </div>
        </div>
    </section>


    {# =============================================================
       5b. CALIBRATION SVG PAR PAYS
       ============================================================= #}
    {% if content.calibration is defined %}
    <section class="inst-section" id="calibration">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.calibration.eyebrow }}</p>
            <h2>{{ content.calibration.title }}</h2>
            <p class="inst-section__lead">{{ content.calibration.lead }}</p>
        </header>

        <div class="inst-calibration-note surface-card">
            <p>{{ content.calibration.note }}</p>
        </div>

        <div class="inst-table-wrapper">
            <table class="inst-table inst-table--calibration">
                <thead>
                    <tr>
                        <th>Pays</th>
                        <th>Seuil pauvreté/mois</th>
                        <th>Ajustement urbain</th>
                        <th>SVG maximum</th>
                        <th>Taux de pauvreté</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in content.calibration.countries %}
                    <tr>
                        <td><strong>{{ row.country }}</strong></td>
                        <td>{{ row.threshold_monthly }}</td>
                        <td>{{ row.urban_adjustment }}</td>
                        <td class="inst-table__highlight">{{ row.svg_max }}</td>
                        <td>{{ row.poverty_rate }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <p class="inst-table-source">{{ content.calibration.source }}</p>
    </section>
    {% endif %}

    {# =============================================================
       5c. CDC VS EURO NUMÉRIQUE BCE
       ============================================================= #}
    {% if content.euroe_vs_cbdc is defined %}
    <section class="inst-section inst-section--alt" id="euroe-vs-cbdc">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.euroe_vs_cbdc.eyebrow }}</p>
            <h2>{{ content.euroe_vs_cbdc.title }}</h2>
            <p class="inst-section__lead">{{ content.euroe_vs_cbdc.lead }}</p>
        </header>

        <div class="inst-table-wrapper">
            <table class="inst-table inst-table--comparison">
                <thead>
                    <tr>
                        <th>Dimension</th>
                        <th>Euro numérique BCE (CBDC)</th>
                        <th>CDC — Civitalisme</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in content.euroe_vs_cbdc.comparison %}
                    <tr>
                        <td><strong>{{ row.dimension }}</strong></td>
                        <td>{{ row.cbdc }}</td>
                        <td class="inst-table__highlight">{{ row.euroe }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="inst-synergy-note surface-card">
            <p class="panel-label">Synergie possible</p>
            <p>{{ content.euroe_vs_cbdc.synergy }}</p>
        </div>
    </section>
    {% endif %}

    {# =============================================================
       5d. CHEMIN LÉGAL
       ============================================================= #}
    {% if content.legal_pathway is defined %}
    <section class="inst-section" id="chemin-legal">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.legal_pathway.eyebrow }}</p>
            <h2>{{ content.legal_pathway.title }}</h2>
            <p class="inst-section__lead">{{ content.legal_pathway.lead }}</p>
        </header>

        <div class="inst-pathway-steps">
            {% for step in content.legal_pathway.steps %}
            <div class="inst-pathway-step surface-card">
                <div class="inst-pathway-step__header">
                    <span class="inst-pathway-step__phase">{{ step.phase }}</span>
                    <span class="inst-pathway-step__base">{{ step.legal_base }}</span>
                </div>
                <h3 class="inst-pathway-step__title">{{ step.title }}</h3>
                <p class="inst-pathway-step__body">{{ step.body }}</p>
                <p class="inst-pathway-step__feasibility">
                    <strong>Faisabilité :</strong> {{ step.feasibility }}
                </p>
            </div>
            {% endfor %}
        </div>

        <div class="inst-key-articles">
            <p class="panel-label">Articles clés des traités</p>
            <div class="inst-key-articles__grid">
                {% for art in content.legal_pathway.key_articles %}
                <div class="inst-key-article surface-card">
                    <span class="inst-key-article__ref">{{ art.ref }}</span>
                    <strong class="inst-key-article__title">{{ art.title }}</strong>
                    <p class="inst-key-article__body">{{ art.body }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}


    {# =============================================================
       5e. CHARTE SVG — CONDITIONS D'AGRÉMENT
       ============================================================= #}
    {% if content.charte_svg is defined %}
    <section class="inst-section inst-section--alt" id="charte-svg">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.charte_svg.eyebrow }}</p>
            <h2>{{ content.charte_svg.title }}</h2>
            <p class="inst-section__lead">{{ content.charte_svg.lead }}</p>
        </header>

        <div class="inst-calibration-note surface-card">
            <p class="panel-label">{{ content.charte_svg.legal_anchor.title }}</p>
            <ul class="feature-list">
                {% for item in content.charte_svg.legal_anchor.items %}
                <li><strong>{{ item.ref }}</strong> — {{ item.body }}</li>
                {% endfor %}
            </ul>
        </div>

        <div class="inst-pathway-steps">
            {% for cat in content.charte_svg.categories %}
            <div class="inst-pathway-step surface-card">
                <div class="inst-pathway-step__header">
                    <span class="inst-pathway-step__phase">{{ cat.label }}</span>
                </div>
                <p class="inst-pathway-step__body">{{ cat.condition }}</p>
                <p class="inst-pathway-step__feasibility"><strong>Exemples :</strong> {{ cat.examples }}</p>
            </div>
            {% endfor %}
        </div>

        <div class="inst-synergy-note surface-card">
            <p class="panel-label">Gouvernance</p>
            <p>{{ content.charte_svg.governance }}</p>
        </div>
    </section>
    {% endif %}

    {# =============================================================
       5f. MODÉLISATION DU COÛT — DONNÉES EMPIRIQUES
       ============================================================= #}
    {% if content.cost_model is defined %}
    <section class="inst-section" id="modelisation-cout">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.cost_model.eyebrow }}</p>
            <h2>{{ content.cost_model.title }}</h2>
            <p class="inst-section__lead">{{ content.cost_model.lead }}</p>
        </header>

        <div class="inst-pathway-steps">
            {% for pilot in content.cost_model.pilots %}
            <div class="inst-pathway-step surface-card">
                <div class="inst-pathway-step__header">
                    <span class="inst-pathway-step__phase">{{ pilot.name }}</span>
                    <span class="inst-pathway-step__base">{{ pilot.period }}</span>
                </div>
                <p><strong>Échelle :</strong> {{ pilot.scale }} — {{ pilot.amount }}</p>
                <ul class="feature-list" style="margin:0.75rem 0">
                    {% for r in pilot.results %}
                    <li>{{ r }}</li>
                    {% endfor %}
                </ul>
                <div class="inst-calibration-note" style="margin-top:0.75rem">
                    <p><strong>Enseignement coût :</strong> {{ pilot.cost_lesson }}</p>
                    <p class="inst-table-source">{{ pilot.source }}</p>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="inst-calibration-note surface-card" style="margin-top:2rem">
            <p class="panel-label">{{ content.cost_model.european_projection.title }}</p>
            <ul class="feature-list">
                {% for a in content.cost_model.european_projection.assumptions %}
                <li>{{ a }}</li>
                {% endfor %}
            </ul>
            <div class="inst-table-wrapper" style="margin-top:1rem">
                <table class="inst-table">
                    <tbody>
                        {% for line in content.cost_model.european_projection.calculation %}
                        <tr><td>{{ line }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <p style="margin-top:0.75rem;font-style:italic;opacity:.7">{{ content.cost_model.european_projection.reference }}</p>
        </div>

        {% if content.cost_model.academic_path is defined %}
        <div class="inst-synergy-note surface-card" style="margin-top:2rem">
            <p class="panel-label">{{ content.cost_model.academic_path.title }}</p>
            {% for contact in content.cost_model.academic_path.contacts %}
            <p><strong>{{ contact.name }}</strong> — {{ contact.role }}</p>
            {% endfor %}
            <p style="margin-top:0.5rem;opacity:.8">{{ content.cost_model.academic_path.approach }}</p>
        </div>
        {% endif %}
    </section>
    {% endif %}

    {# =============================================================
       6. DIALOGUE SOCIAL ET PARTENAIRES SYNDICAUX
       ============================================================= #}
    {% if content.syndical is defined %}
    <section class="inst-section inst-section--panel" id="dialogue-social">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.syndical.eyebrow }}</p>
            <h2>{{ content.syndical.title }}</h2>
            <p class="inst-section__lead">{{ content.syndical.lead }}</p>
        </header>

        <div class="surface-card inst-thesis-card">
            <p class="panel-label">Thèse</p>
            <p>{{ content.syndical.thesis }}</p>
        </div>

        <div class="inst-syndical-grid">
            <div>
                <p class="panel-label">Diagnostic : pourquoi le système actuel ne suffit plus</p>
                <ul class="feature-list">
                    {% for item in content.syndical.diagnosis %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>

            <div>
                <p class="panel-label">Garde-fous structurels</p>
                <div class="card-grid card-grid--two">
                    {% for item in content.syndical.guardrails %}
                        <article class="surface-card narrative-card">
                            <h3>{{ item.title }}</h3>
                            <p>{{ item.body }}</p>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="inst-section__heading inst-section__heading--mid">
            <p class="eyebrow">{{ content.syndical.roleShift.eyebrow }}</p>
            <p class="inst-section__lead">{{ content.syndical.roleShift.lead }}</p>
        </div>

        <div class="inst-comparison-grid">
            {% for shift in content.syndical.roleShift.shifts %}
                <div class="inst-comparison-row">
                    <div class="inst-comparison-row__before">
                        <p class="panel-label">Avant</p>
                        <p>{{ shift.before }}</p>
                    </div>
                    <div class="inst-comparison-row__arrow" aria-hidden="true">→</div>
                    <div class="inst-comparison-row__after">
                        <p class="panel-label">Maintenant</p>
                        <p>{{ shift.after }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="inst-section__heading inst-section__heading--mid">
            <p class="panel-label">Positions des grandes confédérations syndicales européennes</p>
        </div>
        <div class="insight-grid">
            {% for pos in content.syndical.positions %}
                <article class="surface-card insight-card">
                    <p class="panel-label">{{ pos.stance }}</p>
                    <h3>{{ pos.org }}</h3>
                    <p>{{ pos.argument }}</p>
                </article>
            {% endfor %}
        </div>

        <div class="surface-card inst-recommendations-card">
            <p class="panel-label">Recommandations pour le dialogue social</p>
            <ul class="feature-list">
                {% for rec in content.syndical.recommendations %}
                    <li>{{ rec }}</li>
                {% endfor %}
            </ul>
        </div>
    </section>
    {% endif %}

    {# =============================================================
       7. CADRE JURIDIQUE
       ============================================================= #}
    <section class="inst-section">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.legal.eyebrow }}</p>
            <h2>{{ content.legal.title }}</h2>
            <p class="inst-section__lead">{{ content.legal.lead }}</p>
        </header>

        <div class="inst-legal-matrix">
            {% for row in content.legal.matrix %}
                <article class="inst-legal-cell inst-legal-cell--{{ row.status|replace({' ': '-'}) }}">
                    <p class="inst-legal-cell__status">{{ row.status|title }}</p>
                    <h3>{{ row.ref }}</h3>
                    <p class="inst-legal-cell__scope">{{ row.scope }}</p>
                    <p>{{ row.body }}</p>
                </article>
            {% endfor %}
        </div>

        <h3 class="inst-risks__title">Matrice des risques</h3>
        <div class="inst-risks">
            {% for risk in content.legal.risks %}
                <article class="inst-risk inst-risk--{{ risk.level }}">
                    <p class="inst-risk__level">Risque {{ risk.level }}</p>
                    <h4>{{ risk.title }}</h4>
                    <p>{{ risk.body }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    {# =============================================================
       6b. ANALYSES ÉCONOMIQUES — 4 GRAPHIQUES
       ============================================================= #}
    <section class="inst-section inst-section--alt inst-charts-section"
             data-controller="svg-charts">
        <header class="inst-section__heading">
            <p class="eyebrow">Analyses économiques</p>
            <h2>4 chiffres clés pour comprendre le SVG</h2>
            <p class="inst-section__lead">
                Montants, effets sur le travail, coût réel et impact sur la pauvreté —
                données Eurostat SILC 2023, Drees 2024 et littérature académique sur le revenu de base.
            </p>
        </header>

        <div class="inst-charts-grid">
            <div class="inst-chart-card">
                <div class="inst-chart-canvas-wrapper">
                    <canvas data-svg-charts-target="fig3" aria-label="SVG maximal par type de ménage" role="img"></canvas>
                </div>
            </div>
            <div class="inst-chart-card">
                <div class="inst-chart-canvas-wrapper">
                    <canvas data-svg-charts-target="fig4" aria-label="Incitation au travail" role="img"></canvas>
                </div>
            </div>
            <div class="inst-chart-card">
                <div class="inst-chart-canvas-wrapper inst-chart-canvas-wrapper--sm">
                    <canvas data-svg-charts-target="fig5" aria-label="Sources de financement" role="img"></canvas>
                </div>
            </div>
            <div class="inst-chart-card">
                <div class="inst-chart-canvas-wrapper">
                    <canvas data-svg-charts-target="fig6" aria-label="Réduction de la pauvreté" role="img"></canvas>
                </div>
            </div>
        </div>

        <p class="inst-charts-note">
            Fig. 3 : LW₀ France 1 350 €/mois · Eurostat SILC 2023 · Échelle OCDE modifiée.
            Fig. 4 : Franchise 300 €/actif · RSA socle Caisse nationale 2024 (635,71 €).
            Fig. 5 : Projection Civitalisme — Drees 2024, DSS PLF 2025 · 14,8 M bénéficiaires estimés.
            Fig. 6 : Taux AROP avant SVG = Eurostat ilc_li02 2023 · Projection modélisée : réduction ~60 % d'après Kangas et al. 2019 (Kela) et Straubhaar 2017.
        </p>
    </section>

    {# =============================================================
       7. FEUILLE DE ROUTE
       ============================================================= #}
    <section class="inst-section inst-section--alt">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.roadmap.eyebrow }}</p>
            <h2>{{ content.roadmap.title }}</h2>
            <p class="inst-section__lead">{{ content.roadmap.lead }}</p>
        </header>

        <ol class="inst-timeline">
            {% for phase in content.roadmap.phases %}
                <li class="inst-timeline__item">
                    <div class="inst-timeline__marker">
                        <span class="inst-timeline__year">{{ phase.year }}</span>
                        <span class="inst-timeline__phase">{{ phase.phase }}</span>
                    </div>
                    <div class="inst-timeline__body">
                        <h3>{{ phase.title }}</h3>
                        <p>{{ phase.body }}</p>
                        <p class="inst-timeline__kpi">
                            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                                <circle cx="12" cy="12" r="8" fill="none" stroke="#003399" stroke-width="2"/>
                                <circle cx="12" cy="12" r="3" fill="#ffcc00"/>
                            </svg>
                            <span>{{ phase.kpi }}</span>
                        </p>
                    </div>
                </li>
            {% endfor %}
        </ol>
    </section>

    {% include 'page/civitalisme/_partials/_updates_feed.html.twig' with {
        eyebrow: 'Notes de travail',
        title: 'Articles institutionnels',
        lead: 'Des compléments publiés depuis l’admin : arguments, sources, jalons et réponses aux objections.',
        updates: projectUpdates,
    } only %}

    {# =============================================================
       8. TÉLÉCHARGEMENTS
       ============================================================= #}
    <section class="inst-section" id="telechargements">
        <header class="inst-section__heading">
            <p class="eyebrow">{{ content.downloads.eyebrow }}</p>
            <h2>{{ content.downloads.title }}</h2>
            <p class="inst-section__lead">{{ content.downloads.lead }}</p>
        </header>

        <ul class="inst-downloads">
            {% for item in content.downloads.items %}
                <li>
                    <a href="{{ item.href }}" download>
                        <svg class="inst-downloads__icon" viewBox="0 0 48 60" width="40" height="50" aria-hidden="true" focusable="false">
                            <path d="M4 4 H30 L44 18 V56 H4 Z" fill="#ffffff" stroke="#003399" stroke-width="2" stroke-linejoin="round"/>
                            <path d="M30 4 V18 H44" fill="none" stroke="#003399" stroke-width="2" stroke-linejoin="round"/>
                            <rect x="10" y="32" width="28" height="4" rx="1" fill="#003399"/>
                            <rect x="10" y="40" width="20" height="4" rx="1" fill="#003399" opacity="0.6"/>
                            <rect x="10" y="48" width="24" height="4" rx="1" fill="#003399" opacity="0.4"/>
                            <rect x="2" y="44" width="22" height="12" rx="2" fill="#003399"/>
                            <text x="13" y="53" font-family="Inter, sans-serif" font-weight="700" font-size="8" fill="#ffcc00">PDF</text>
                        </svg>
                        <div>
                            <h3>{{ item.title }}</h3>
                            <small>{{ item.size }} — téléchargement libre</small>
                        </div>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </section>

    {# =============================================================
       9. CONTACT INSTITUTIONNEL
       ============================================================= #}
    <section class="inst-section inst-contact" id="contact-institutionnel">
        <div class="inst-contact__intro">
            <p class="eyebrow">{{ content.cta.eyebrow }}</p>
            <h2>{{ content.cta.title }}</h2>
            <p class="inst-section__lead">{{ content.cta.body }}</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="inst-flash inst-flash--{{ label }}">
                    <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
                        {% if label == 'success' %}
                            <path d="M5 12.5 L10 17.5 L19 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        {% else %}
                            <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/>
                            <path d="M12 8 V12 M12 16 V16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        {% endif %}
                    </svg>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}
        {% endfor %}

        {{ form_start(contactForm, {
            attr: { class: 'inst-contact-form', novalidate: 'novalidate' }
        }) }}

        <div class="inst-contact-form__grid">
            <div class="inst-contact-form__field">
                {{ form_label(contactForm.name) }}
                {{ form_widget(contactForm.name, { attr: { class: 'inst-input' } }) }}
                {{ form_errors(contactForm.name) }}
            </div>
            <div class="inst-contact-form__field">
                {{ form_label(contactForm.email) }}
                {{ form_widget(contactForm.email, { attr: { class: 'inst-input' } }) }}
                {{ form_errors(contactForm.email) }}
            </div>
            <div class="inst-contact-form__field">
                {{ form_label(contactForm.company) }}
                {{ form_widget(contactForm.company, { attr: { class: 'inst-input' } }) }}
                {{ form_errors(contactForm.company) }}
            </div>
            <div class="inst-contact-form__field">
                {{ form_label(contactForm.subject) }}
                {{ form_widget(contactForm.subject, { attr: { class: 'inst-select' } }) }}
                {{ form_errors(contactForm.subject) }}
            </div>
            <div class="inst-contact-form__field inst-contact-form__field--full">
                {{ form_label(contactForm.message) }}
                {{ form_widget(contactForm.message, { attr: { class: 'inst-textarea' } }) }}
                {{ form_errors(contactForm.message) }}
            </div>
            <div class="inst-contact-form__field inst-contact-form__field--full inst-contact-form__field--consent">
                {{ form_widget(contactForm.consent) }}
                {{ form_label(contactForm.consent) }}
                {{ form_errors(contactForm.consent) }}
            </div>
        </div>

        {# Honeypot anti-spam — caché #}
        <div style="display:none" aria-hidden="true">
            {{ form_widget(contactForm.website) }}
        </div>

        {{ form_rest(contactForm) }}

        <div class="inst-contact-form__footer">
            <button class="button" type="submit">Envoyer le message</button>
            <p class="inst-contact-form__rgpd">
                Vos données sont traitées conformément au RGPD, hébergées en Europe,
                et utilisées uniquement pour répondre à votre demande.
            </p>
        </div>

        {{ form_end(contactForm) }}

        <p class="inst-cta__footnote">Projet Civitalisme — Hébergé en Europe — Données protégées — Document de travail ouvert.</p>
    </section>
{% endblock %}
