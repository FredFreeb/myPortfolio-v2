<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Portfolio + Civitalisme{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Portfolio, parcours et projet Civitalisme dans une application Symfony sobre, éditable et maintenable.{% endblock %}">
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {{ importmap('app') }}
</head>
{% set currentRoute = app.request.attributes.get('_route') ?? '' %}
<body class="{% block body_class %}theme-portfolio{% endblock %}">
    <div class="site-background" aria-hidden="true">
        <div class="site-background__orb site-background__orb--one"></div>
        <div class="site-background__orb site-background__orb--two"></div>
        <div class="site-background__grid"></div>
    </div>

    <div class="site-shell">
        {% include '_partials/_site_header.html.twig' with {
            currentRoute: currentRoute,
        } only %}

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash--{{ label == 'error' ? 'error' : 'success' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <main class="page-main">
            {% block body %}{% endblock %}
        </main>

        {% include '_partials/_site_footer.html.twig' %}
    </div>
    <script>
        (function () {
            var MOBILE_BREAKPOINT = '(max-width: 860px)';

            function initSimpleMobileNav() {
                var header = document.querySelector('.site-header');
                if (!header || header.dataset.navSimpleInitialized === 'true') {
                    return;
                }

                var button = header.querySelector('.nav-toggle');
                var panel = header.querySelector('.site-header__panel');
                var backdrop = header.querySelector('.site-header__backdrop');
                var links = header.querySelectorAll('.site-nav__link');
                if (!button || !panel) {
                    return;
                }

                var mediaQuery = window.matchMedia(MOBILE_BREAKPOINT);

                function isMobile() {
                    return mediaQuery.matches;
                }

                function openMenu() {
                    if (!isMobile()) {
                        return;
                    }
                    header.classList.add('is-open');
                    button.setAttribute('aria-expanded', 'true');
                    button.setAttribute('aria-label', 'Fermer la navigation');
                    document.body.classList.add('has-mobile-nav');
                }

                function closeMenu() {
                    header.classList.remove('is-open');
                    button.setAttribute('aria-expanded', 'false');
                    button.setAttribute('aria-label', 'Ouvrir la navigation');
                    document.body.classList.remove('has-mobile-nav');
                }

                function toggleMenu(event) {
                    event.preventDefault();
                    if (!isMobile()) {
                        return;
                    }
                    if (header.classList.contains('is-open')) {
                        closeMenu();
                    } else {
                        openMenu();
                    }
                }

                button.addEventListener('click', toggleMenu);
                if (backdrop) {
                    backdrop.addEventListener('click', closeMenu);
                }
                for (var i = 0; i < links.length; i += 1) {
                    links[i].addEventListener('click', closeMenu);
                }
                document.addEventListener('keydown', function (event) {
                    if (event.key === 'Escape') {
                        closeMenu();
                    }
                });

                function onViewportChange() {
                    if (!isMobile()) {
                        closeMenu();
                    }
                }

                if (typeof mediaQuery.addEventListener === 'function') {
                    mediaQuery.addEventListener('change', onViewportChange);
                } else if (typeof mediaQuery.addListener === 'function') {
                    mediaQuery.addListener(onViewportChange);
                }

                header.dataset.navSimpleInitialized = 'true';
                closeMenu();
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initSimpleMobileNav, { once: true });
            } else {
                initSimpleMobileNav();
            }
            document.addEventListener('turbo:load', initSimpleMobileNav);
        })();
    </script>
</body>
</html>
