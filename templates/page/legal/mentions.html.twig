{% extends 'base.html.twig' %}

{% block title %}Mentions légales | Portfolio + Civitalisme{% endblock %}
{% block meta_description %}Mentions légales de fribel.eu : éditeur, contact, hébergement, propriété intellectuelle et cadre de publication du site Portfolio + Civitalisme.{% endblock %}
{% block body_class %}theme-portfolio page-legal page-legal--mentions{% endblock %}

{% block body %}
    <section class="legal-hero">
        <div class="legal-hero__copy">
            <p class="eyebrow">Cadre de publication</p>
            <h1>Mentions légales</h1>
            <p>
                Les informations essentielles pour identifier l’éditeur du site,
                comprendre son hébergement et connaître les règles de réutilisation des contenus.
            </p>
        </div>

        <aside class="legal-hero__panel">
            <span>Site éditorial personnel</span>
            <strong>{{ editor.site }}</strong>
            <p>Portfolio, publications, contact et documentation autour du projet Civitalisme.</p>
        </aside>
    </section>

    <section class="legal-layout">
        <aside class="legal-summary" aria-label="Résumé des mentions légales">
            <p class="eyebrow">En bref</p>
            <dl>
                <div>
                    <dt>Éditeur</dt>
                    <dd>{{ editor.name }}</dd>
                </div>
                <div>
                    <dt>Hébergement</dt>
                    <dd>{{ hosting.name }}</dd>
                </div>
                <div>
                    <dt>Objet</dt>
                    <dd>Présentation, publication et prise de contact.</dd>
                </div>
                <div>
                    <dt>Dernière mise à jour</dt>
                    <dd>{{ "now"|date("d/m/Y") }}</dd>
                </div>
            </dl>
        </aside>

        <div class="legal-content">
            <article class="legal-card">
                <p class="eyebrow">Éditeur</p>
                <h2>{{ editor.name }}</h2>
                <p>{{ editor.role }} du site {{ editor.site }}.</p>
                <p>
                    Les textes, choix éditoriaux, pages publiques et contenus de présentation
                    sont publiés sous la responsabilité de l’éditeur du site.
                </p>
            </article>

            <article class="legal-card">
                <p class="eyebrow">Contact</p>
                <h2>Canaux publics</h2>
                <p>Pour toute demande, correction ou prise de contact professionnelle, utilisez l’un des canaux ci-dessous.</p>
                <ul class="legal-link-list">
                    {% for link in contactLinks %}
                        <li>
                            <a href="{{ link.url }}" target="_blank" rel="noreferrer">{{ link.label }}</a>
                            <span>{{ link.description }}</span>
                        </li>
                    {% endfor %}
                    <li>
                        <a href="{{ path('app_contact') }}">Formulaire de contact</a>
                        <span>Demandes directes depuis le site.</span>
                    </li>
                </ul>
            </article>

            <article class="legal-card">
                <p class="eyebrow">Hébergement</p>
                <h2>{{ hosting.name }}</h2>
                <p>{{ hosting.body }}</p>
                <dl class="legal-details">
                    <div>
                        <dt>Adresse</dt>
                        <dd>{{ hosting.address }}</dd>
                    </div>
                    <div>
                        <dt>Site web</dt>
                        <dd><a href="{{ hosting.website }}" target="_blank" rel="noreferrer">{{ hosting.website }}</a></dd>
                    </div>
                </dl>
            </article>

            <article class="legal-card legal-card--wide">
                <p class="eyebrow">Propriété intellectuelle</p>
                <h2>Textes, images, interfaces et code</h2>
                <div class="legal-columns">
                    <p>
                        Les contenus publiés sur ce site, notamment les textes, maquettes,
                        visuels, éléments d’interface et documents de présentation, sont protégés
                        par le droit applicable, sauf mention contraire ou lien explicite vers une source externe.
                    </p>
                    <p>
                        Toute reprise substantielle, reproduction ou adaptation doit faire l’objet
                        d’une autorisation préalable. Les citations courtes restent possibles dans
                        le respect du droit de citation et avec mention claire de la source.
                    </p>
                </div>
            </article>
        </div>
    </section>
{% endblock %}
