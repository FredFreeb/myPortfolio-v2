{% extends 'base.html.twig' %}

{% block title %}Civitalisme — Socle Vital Garanti européen{% endblock %}
{% block meta_description %}Le Civitalisme porte le projet Socle Vital Garanti : un complément mensuel automatique qui couvre les besoins essentiels de chaque Européen — logement, alimentation, énergie, transport — sans formulaire ni dossier.{% endblock %}
{% block body_class %}theme-civitalisme page-civitalisme page-civitalisme--public{% endblock %}

{% block extra_head %}
<style>
/* ── Dark mode — articles section ───────────────────────────────────────── */
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-articles {
    background:
        linear-gradient(135deg, rgba(10, 30, 80, 0.70), rgba(5, 15, 50, 0.55)),
        radial-gradient(circle at top right, rgba(100, 160, 255, 0.08), transparent 34%);
    border-color: rgba(100, 160, 255, 0.16);
}
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-articles .eyebrow {
    color: var(--muted);
}
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-articles h2 {
    color: var(--text);
}
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-articles .section-intro {
    color: var(--muted);
}
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-article {
    background: rgba(10, 25, 70, 0.65);
    border-color: rgba(100, 160, 255, 0.14);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.40);
}
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-article--featured {
    background: rgba(10, 25, 70, 0.75);
    border-color: rgba(255, 204, 0, 0.22);
}
html[data-color-scheme="dark"] body.theme-civitalisme .civitalisme-article h3 {
    color: var(--text);
}

/* ── Schémas pédagogiques ────────────────────────────────────────────────── */
.gp-schemas {
    padding: 3rem 1.5rem 4rem;
}
.gp-schemas .ped-intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 2.5rem;
}
.gp-schemas .ped-intro h2 {
    font-size: 1.6rem;
    font-weight: 800;
    color: #003399;
    margin-bottom: .5rem;
}
.gp-schemas .ped-intro p {
    font-size: 1rem;
    color: #6b7280;
}
.gp-schemas .ped-schema {
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 32px rgba(0,51,153,.1);
    overflow: hidden;
    margin-bottom: 2.5rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
}
.gp-schemas .ped-schema-header {
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
}
.gp-schemas .ped-schema-header .ped-badge {
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    font-weight: 900;
    color: white;
}
.gp-schemas .ped-schema-header h3 {
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.2;
    color: white;
}
.gp-schemas .ped-schema-header p {
    font-size: .8rem;
    color: #96b0e8;
    margin-top: .15rem;
}
.gp-schemas .ped-body {
    padding: 1.5rem 2rem 2rem;
}
/* Zone */
.gp-schemas .ped-zone {
    border-radius: 14px;
    padding: 1.25rem;
    margin-bottom: 1rem;
}
.gp-schemas .ped-zone-label {
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
    margin-bottom: .75rem;
    display: flex;
    align-items: center;
    gap: .4rem;
}
.gp-schemas .ped-zone-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: .25;
}
/* Nodes */
.gp-schemas .ped-nodes {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    align-items: stretch;
}
.gp-schemas .ped-node {
    flex: 1;
    min-width: 150px;
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
}
.gp-schemas .ped-node-icon { font-size: 1.6rem; line-height: 1; margin-bottom: .25rem; }
.gp-schemas .ped-node-title { font-size: .95rem; font-weight: 800; line-height: 1.2; }
.gp-schemas .ped-node-sub  { font-size: .78rem; opacity: .8; line-height: 1.35; }
.gp-schemas .ped-node-tag {
    display: inline-block;
    padding: .15rem .5rem;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 700;
    margin-top: .3rem;
    width: fit-content;
}
/* Arrow */
.gp-schemas .ped-arrow-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    margin: .6rem 0;
}
.gp-schemas .ped-arrow-down {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .15rem;
}
.gp-schemas .ped-arrow-line { width: 2px; height: 28px; border-radius: 2px; }
.gp-schemas .ped-arrow-head { width: 0; height: 0; border-left: 7px solid transparent; border-right: 7px solid transparent; }
.gp-schemas .ped-arrow-label {
    font-size: .78rem;
    font-weight: 600;
    padding: .2rem .7rem;
    border-radius: 20px;
    white-space: nowrap;
}
/* Rails */
.gp-schemas .ped-rails {
    display: grid;
    grid-template-columns: 1fr 36px 1fr;
    gap: 0;
    align-items: center;
}
.gp-schemas .ped-rail { border-radius: 12px; padding: 1rem; }
.gp-schemas .ped-rail-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 900;
    color: #c0392b;
}
/* Points */
.gp-schemas .ped-points { display: flex; flex-direction: column; gap: .4rem; margin-top: .5rem; }
.gp-schemas .ped-point { display: flex; align-items: flex-start; gap: .5rem; font-size: .8rem; line-height: 1.35; }
.gp-schemas .ped-dot {
    width: 18px; height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem;
    font-weight: 900;
    margin-top: 1px;
    color: white;
}
/* Compare */
.gp-schemas .ped-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.gp-schemas .ped-compare-col { border-radius: 14px; padding: 1.25rem; }
.gp-schemas .ped-compare-title { font-size: .85rem; font-weight: 800; margin-bottom: .75rem; display: flex; align-items: center; gap: .5rem; }
/* Steps */
.gp-schemas .ped-steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
    position: relative;
    margin-bottom: 1.25rem;
}
.gp-schemas .ped-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: .4rem;
    position: relative;
    padding: 0 .25rem;
}
.gp-schemas .ped-step::after {
    content: '';
    position: absolute;
    top: 18px;
    left: 55%;
    width: 90%;
    height: 2px;
    background: #003399;
    opacity: .2;
    z-index: 0;
}
.gp-schemas .ped-step:last-child::after { display: none; }
.gp-schemas .ped-step-num {
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem;
    font-weight: 900;
    color: white;
    z-index: 1;
    position: relative;
    flex-shrink: 0;
}
.gp-schemas .ped-step-label { font-size: .75rem; font-weight: 700; color: #003399; line-height: 1.3; }
.gp-schemas .ped-step-sub   { font-size: .7rem; color: #6b7280; line-height: 1.3; }
/* Callout */
.gp-schemas .ped-callout {
    border-radius: 12px;
    padding: 1rem 1.25rem;
    font-size: .82rem;
    line-height: 1.5;
    display: flex;
    gap: .75rem;
    align-items: flex-start;
    margin-top: .75rem;
}
.gp-schemas .ped-callout-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: .05rem; }
/* Tags pill */
.gp-schemas .ped-pills { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .4rem; }
.gp-schemas .ped-pill { background: #003399; color: white; padding: .2rem .6rem; border-radius: 20px; font-size: .73rem; font-weight: 600; }
/* Transition barre */
.gp-schemas .ped-transition {
    display: flex; align-items: center; justify-content: center;
    gap: 1rem; margin: 1.25rem 0;
}
.gp-schemas .ped-transition-bar { flex: 1; height: 2px; }
.gp-schemas .ped-transition-label {
    background: #003399; color: white;
    border-radius: 20px; padding: .5rem 1.25rem;
    font-size: .82rem; font-weight: 700; white-space: nowrap;
}
/* Couleurs utilitaires */
.gp-schemas .bg-navy      { background: #003399; color: white; }
.gp-schemas .bg-navy-lt   { background: #e8eefc; color: #003399; }
.gp-schemas .bg-gold      { background: #ffcc00; color: #3a2800; }
.gp-schemas .bg-gold-soft { background: #fff9e0; color: #6b4c00; }
.gp-schemas .bg-green     { background: #1a7a5e; color: white; }
.gp-schemas .bg-green-lt  { background: #e6f5ef; color: #1a7a5e; }
.gp-schemas .bg-red       { background: #c0392b; color: white; }
.gp-schemas .bg-red-lt    { background: #fdecea; color: #c0392b; }
.gp-schemas .bg-grey-lt   { background: #f3f4f6; color: #6b7280; }
.gp-schemas .bg-white     { background: white; }
.gp-schemas .c-navy   { color: #003399; }
.gp-schemas .c-gold   { color: #b38a00; }
.gp-schemas .c-green  { color: #1a7a5e; }
.gp-schemas .c-red    { color: #c0392b; }
.gp-schemas .c-grey   { color: #6b7280; }
.gp-schemas .b-navy   { border: 2px solid #003399; }
.gp-schemas .b-gold   { border: 2px solid #ffcc00; }
.gp-schemas .b-green  { border: 2px solid #1a7a5e; }
.gp-schemas .b-red    { border: 2px solid #c0392b; }
.gp-schemas .b-grey   { border: 1.5px solid #d1d5db; }
.gp-schemas .b-dashed { border-style: dashed !important; }
/* Dark mode */
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas {
    background: transparent;
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-schema {
    background: rgba(10, 25, 70, 0.75);
    box-shadow: 0 4px 32px rgba(0,0,0,.4);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-zone.bg-navy-lt {
    background: rgba(0,51,153,.2);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-zone.bg-gold-soft {
    background: rgba(255,204,0,.08);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-zone.bg-grey-lt {
    background: rgba(255,255,255,.05);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-zone.bg-green-lt {
    background: rgba(26,122,94,.12);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-zone.bg-red-lt {
    background: rgba(192,57,43,.12);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-node.bg-white {
    background: rgba(255,255,255,.07);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-compare-col.bg-grey-lt {
    background: rgba(255,255,255,.05);
    color: #96b0e8;
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-intro h2 {
    color: var(--text);
}
html[data-color-scheme="dark"] body.theme-civitalisme .gp-schemas .ped-rail.bg-grey-lt {
    background: rgba(255,255,255,.05);
}
@media (max-width: 640px) {
    .gp-schemas .ped-compare { grid-template-columns: 1fr; }
    .gp-schemas .ped-rails   { grid-template-columns: 1fr; gap: .5rem; }
    .gp-schemas .ped-rail-divider { display: none; }
    .gp-schemas .ped-steps { flex-wrap: wrap; gap: .75rem; }
    .gp-schemas .ped-step::after { display: none; }
    .gp-schemas .ped-body { padding: 1rem; }
}
</style>
{% endblock %}

{% block body %}

    {# ── 1. Hero ─────────────────────────────────────────────────────────── #}
    <section class="gp-hero section--panel">
        <div class="gp-hero__copy">
            <p class="eyebrow">{{ content.hero.eyebrow }}</p>
            <h1 class="gp-hero__title">{{ content.hero.title }}</h1>
            <p class="gp-hero__subtitle">{{ content.hero.subtitle }}</p>
            <p class="gp-hero__lead">{{ content.hero.lead }}</p>

            <div class="gp-hero__actions">
                <a class="button" href="{{ content.hero.primaryCta.href }}">
                    {{ content.hero.primaryCta.label }}
                    <span aria-hidden="true">↓</span>
                </a>
                <a class="button button--ghost" href="{{ path('app_civitalisme_technical') }}">
                    {{ content.hero.secondaryCta.label }}
                </a>
            </div>

            {# Stat chips #}
            <div class="gp-hero__stats" aria-label="Quelques chiffres clés">
                {% for stat in content.hero.stats %}
                <div class="gp-hero__stat">
                    <strong class="gp-hero__stat-value">{{ stat.value }}</strong>
                    <span class="gp-hero__stat-label">{{ stat.label }}</span>
                </div>
                {% endfor %}
            </div>
        </div>

        <div class="gp-hero__illustration" aria-hidden="true">
            <svg viewBox="0 0 480 360" xmlns="http://www.w3.org/2000/svg" role="img">
                <title>Une famille traverse un pont lumineux au-dessus d'un gouffre</title>
                <defs>
                    <linearGradient id="gp-sky" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#f5f8fc"/>
                        <stop offset="60%" stop-color="#ffe6cc"/>
                        <stop offset="100%" stop-color="#fff3b8"/>
                    </linearGradient>
                    <linearGradient id="gp-bridge" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#4266b8"/>
                        <stop offset="100%" stop-color="#003399"/>
                    </linearGradient>
                    <linearGradient id="gp-chasm" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#003399" stop-opacity="0.15"/>
                        <stop offset="100%" stop-color="#003399" stop-opacity="0.45"/>
                    </linearGradient>
                </defs>
                <rect width="480" height="360" fill="url(#gp-sky)"/>
                <circle cx="370" cy="90" r="38" fill="#ffcc00" opacity="0.85"/>
                <circle cx="370" cy="90" r="52" fill="#ffcc00" opacity="0.18"/>
                <path d="M0 240 L160 230 L170 360 L0 360 Z" fill="url(#gp-chasm)"/>
                <path d="M320 230 L480 240 L480 360 L310 360 Z" fill="url(#gp-chasm)"/>
                <path d="M140 220 Q240 140 340 220" stroke="url(#gp-bridge)" stroke-width="6" fill="none" stroke-linecap="round"/>
                <path d="M150 230 Q240 160 330 230 L330 240 Q240 170 150 240 Z" fill="url(#gp-bridge)"/>
                <rect x="145" y="218" width="190" height="8" rx="4" fill="#003399"/>
                <g transform="translate(168 168)">
                    <circle cx="0" cy="0" r="8" fill="#003399"/>
                    <path d="M-6 8 Q-6 30 -4 44 L 4 44 Q 6 30 6 8 Z" fill="#003399"/>
                    <line x1="8" y1="10" x2="12" y2="48" stroke="#003399" stroke-width="2" stroke-linecap="round"/>
                </g>
                <g transform="translate(210 158)">
                    <circle cx="0" cy="0" r="9" fill="#003399"/>
                    <path d="M-8 10 Q-9 36 -6 52 L 6 52 Q 9 36 8 10 Z" fill="#003399"/>
                </g>
                <g transform="translate(244 178)">
                    <circle cx="0" cy="0" r="6" fill="#003399"/>
                    <path d="M-5 7 Q-6 24 -4 36 L 4 36 Q 6 24 5 7 Z" fill="#003399"/>
                </g>
                <g transform="translate(282 158)">
                    <circle cx="0" cy="0" r="9" fill="#003399"/>
                    <path d="M-8 10 Q-9 36 -6 52 L 6 52 Q 9 36 8 10 Z" fill="#003399"/>
                </g>
                <circle cx="180" cy="110" r="3" fill="#ffcc00" opacity="0.6"/>
                <circle cx="220" cy="80" r="2" fill="#ffcc00" opacity="0.5"/>
                <circle cx="280" cy="95" r="2.5" fill="#ffcc00" opacity="0.55"/>
                <circle cx="310" cy="125" r="3" fill="#ffcc00" opacity="0.5"/>
            </svg>
        </div>
    </section>

    {# ── 2. "En 30 secondes" strip ────────────────────────────────────────── #}
    <section class="section section--panel section--alt gp-brief" aria-labelledby="gp-brief-title">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.brief.eyebrow }}</p>
        </header>
        <div class="gp-brief__steps">
            {% for step in content.brief.steps %}
            <div class="gp-brief__step">
                <div class="gp-brief__icon" aria-hidden="true">
                    {% if step.icon == 'calc' %}
                        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="8" y="6" width="32" height="36" rx="4" fill="none" stroke="currentColor" stroke-width="2.5"/><rect x="13" y="11" width="22" height="8" rx="2" fill="currentColor" opacity="0.15"/><circle cx="16" cy="28" r="2.5" fill="currentColor"/><circle cx="24" cy="28" r="2.5" fill="currentColor"/><circle cx="32" cy="28" r="2.5" fill="currentColor"/><circle cx="16" cy="36" r="2.5" fill="currentColor"/><circle cx="24" cy="36" r="2.5" fill="currentColor"/><circle cx="32" cy="36" r="2.5" fill="#ffcc00"/></svg>
                    {% elseif step.icon == 'card' %}
                        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="12" width="40" height="24" rx="4" fill="none" stroke="currentColor" stroke-width="2.5"/><rect x="4" y="19" width="40" height="5" fill="currentColor" opacity="0.18"/><rect x="10" y="29" width="10" height="4" rx="1.5" fill="#ffcc00"/><circle cx="36" cy="31" r="3.5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="32" cy="31" r="3.5" fill="none" stroke="#ffcc00" stroke-width="2"/></svg>
                    {% elseif step.icon == 'shop' %}
                        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="M8 16 L12 8 L36 8 L40 16 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/><rect x="8" y="16" width="32" height="24" rx="2" fill="none" stroke="currentColor" stroke-width="2.5"/><rect x="18" y="28" width="12" height="12" rx="1" fill="currentColor" opacity="0.18"/><path d="M18 16 Q18 22 24 22 Q30 22 30 16" fill="none" stroke="#ffcc00" stroke-width="2.5" stroke-linecap="round"/></svg>
                    {% elseif step.icon == 'loop' %}
                        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="M24 10 Q36 10 38 22 Q40 34 28 36" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M24 38 Q12 38 10 26 Q8 14 20 12" fill="none" stroke="#ffcc00" stroke-width="2.5" stroke-linecap="round"/><polygon points="24,6 28,14 20,14" fill="currentColor"/><polygon points="24,42 20,34 28,34" fill="#ffcc00"/></svg>
                    {% endif %}
                </div>
                <h3 class="gp-brief__step-title">{{ step.title }}</h3>
                <p class="gp-brief__step-body">{{ step.body }}</p>
            </div>
            {% endfor %}
        </div>
    </section>

    {# ── 3. Problem ───────────────────────────────────────────────────────── #}
    <section id="{{ content.problem.anchor }}" class="section section--panel gp-problem">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.problem.eyebrow }}</p>
            <h2>{{ content.problem.title }}</h2>
            <p class="section-intro">{{ content.problem.lead }}</p>
        </header>

        <div class="gp-problem-grid">
            {% for card in content.problem.cards %}
                <article class="gp-problem-card surface-card">
                    <div class="gp-problem-card__illustration" aria-hidden="true">
                        {% if card.illustration == 'robot-desk' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <rect x="14" y="78" width="92" height="6" rx="2" fill="#003399"/>
                                <rect x="20" y="84" width="6" height="24" fill="#003399"/>
                                <rect x="94" y="84" width="6" height="24" fill="#003399"/>
                                <rect x="40" y="40" width="40" height="36" rx="6" fill="#4266b8"/>
                                <circle cx="52" cy="56" r="4" fill="#ffcc00"/>
                                <circle cx="68" cy="56" r="4" fill="#ffcc00"/>
                                <rect x="50" y="66" width="20" height="4" rx="2" fill="#f5f8fc"/>
                                <line x1="60" y1="28" x2="60" y2="40" stroke="#003399" stroke-width="3" stroke-linecap="round"/>
                                <circle cx="60" cy="26" r="4" fill="#ffcc00"/>
                                <rect x="46" y="76" width="28" height="4" fill="#003399"/>
                            </svg>
                        {% elseif card.illustration == 'falling-chart' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <rect x="16" y="100" width="88" height="4" rx="2" fill="#003399"/>
                                <rect x="24" y="42" width="14" height="60" rx="2" fill="#4266b8"/>
                                <rect x="44" y="58" width="14" height="44" rx="2" fill="#4266b8" opacity="0.75"/>
                                <rect x="64" y="72" width="14" height="30" rx="2" fill="#4266b8" opacity="0.55"/>
                                <rect x="84" y="86" width="14" height="16" rx="2" fill="#4266b8" opacity="0.4"/>
                                <path d="M28 36 L 50 52 L 70 66 L 92 82" stroke="#ffcc00" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                                <polygon points="88,80 98,84 92,92" fill="#ffcc00"/>
                            </svg>
                        {% elseif card.illustration == 'household-bill' %}
                            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                                <rect x="28" y="22" width="60" height="80" rx="4" fill="#ffffff" stroke="#003399" stroke-width="2"/>
                                <line x1="38" y1="38" x2="78" y2="38" stroke="#4266b8" stroke-width="2"/>
                                <line x1="38" y1="48" x2="68" y2="48" stroke="#4266b8" stroke-width="2" opacity="0.7"/>
                                <line x1="38" y1="58" x2="72" y2="58" stroke="#4266b8" stroke-width="2" opacity="0.7"/>
                                <line x1="38" y1="68" x2="60" y2="68" stroke="#4266b8" stroke-width="2" opacity="0.7"/>
                                <text x="58" y="92" font-family="Inter, sans-serif" font-size="18" font-weight="700" fill="#003399" text-anchor="middle">€</text>
                                <circle cx="82" cy="28" r="10" fill="#ffcc00"/>
                                <text x="82" y="32" font-family="Inter, sans-serif" font-size="12" font-weight="700" fill="#003399" text-anchor="middle">!</text>
                            </svg>
                        {% endif %}
                    </div>
                    {% if card.stat is defined %}
                    <div class="gp-problem-card__stat" aria-hidden="true">{{ card.stat }}</div>
                    {% endif %}
                    <h3>{{ card.title }}</h3>
                    <p>{{ card.body }}</p>
                </article>
            {% endfor %}
        </div>

        <div class="gp-problem__transition">
            <p class="gp-problem__transition-text">{{ content.problem.transition.text }}</p>
            <p class="gp-problem__transition-accent">{{ content.problem.transition.accent }}</p>
        </div>
    </section>

    {# ── 4. Solution ──────────────────────────────────────────────────────── #}
    <section class="section section--panel section--alt gp-solution">
        <header class="section-heading section-heading--centered">
            <p class="eyebrow">{{ content.solution.eyebrow }}</p>
            <h2>{{ content.solution.title }}</h2>
            <p class="section-intro">{{ content.solution.lead }}</p>
        </header>

        {# Formula callout #}
        <div class="gp-solution__formula surface-card">
            <p class="gp-solution__formula-label">{{ content.solution.formula.label }}</p>
            <p class="gp-solution__formula-text">{{ content.solution.formula.text }}</p>
            <p class="gp-solution__formula-note">{{ content.solution.formula.note }}</p>
        </div>

        <div class="gp-solution__diagram">
            <svg viewBox="0 0 480 480" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="svg-solution-title">
