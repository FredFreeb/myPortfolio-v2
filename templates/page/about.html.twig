{% extends 'base.html.twig' %}

{% block title %}About me | Frédéric Fribel{% endblock %}
{% block meta_description %}Parcours, environnement de travail, passions et approche métier autour du web, de l’IA et de la poésie.{% endblock %}
{% block body_class %}theme-portfolio page-about{% endblock %}

{% block body %}
    <section class="hero hero--inner hero--about">
        <div class="hero__copy">
            <p class="eyebrow">A propos de mon travail</p>
            <h1 class="hero__title hero__title--medium hero__title--heartbeat" data-controller="pretext" data-pretext-line-height-value="62">
                Développer des sites web vivants
            </h1>
            <p class="hero__lead">
                Développeur web formé aux environnements modernes, j’ai également construit une solide expérience en accompagnement utilisateur et support client.
Mon parcours m’a conduit à évoluer vers des fonctions d’adjoint de direction, alliant gestion, organisation et relation publique.
Aujourd’hui, je mets ces compétences au service de projets où technique, humain et structuration se rencontrent.
            </p>

            <div class="hero__actions">
                <a class="button" href="https://www.linkedin.com/in/FredFreeb" target="_blank" rel="noreferrer">Voir mon profil public</a>
                <a class="button button--ghost" href="{{ path('app_contact') }}">Échanger avec moi</a>
            </div>
        </div>

        <aside class="surface-card about-identity">
            <div class="about-identity__header">
                <div class="about-identity__badge">
                    <img src="{{ asset('images/profile/fred-linkedin-brand.jpg') }}" alt="Avatar public de Fred">
                </div>
                <div class="about-identity__copy">
                    <p class="panel-label">Profil public</p>
                    <h2>Développement web, projets sur mesure</h2>
                    <p>Je privilégie un code clair et sécurisé, des structures maintenables et des solutions sur mesure, facilement administrables et adaptées aux besoins réels, plutôt que des outils standardisés difficiles à faire évoluer.</p>
                </div>
            </div>

            <div class="metric-strip metric-strip--stacked">
                {% for item in profileHighlights %}
                    <div class="metric-chip">
                        <strong>{{ item.label }}</strong>
                        <span>{{ item.value }}</span>
                    </div>
                {% endfor %}
            </div>
        </aside>
    </section>

    <section class="section section--panel section--panel-sun">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Expériences</p>
                <h2>Parcours professionnel</h2>
            </div>
        </div>

        <div class="experience-grid">
            {% for item in experienceTimeline %}
                <article class="surface-card experience-card experience-card--{{ item.theme }}">
                    <div class="experience-card__header">
                        <div class="experience-card__logo" aria-hidden="true">
                            {% if item.logoPath %}
                                <img src="{{ asset(item.logoPath) }}" alt="{{ item.companyName }}">
                            {% else %}
                                <span>{{ item.monogram|default(item.companyName|slice(0, 3)|upper) }}</span>
                            {% endif %}
                        </div>

                        <div class="experience-card__meta">
                            <span>{{ item.location }}</span>
                            <span>{{ item.status }}</span>
                        </div>
                    </div>
                    <h3 class="experience-card__title" data-controller="pretext" data-pretext-line-height-value="42">{{ item.companyName }}</h3>
                    <p class="experience-card__role">{{ item.role }}</p>
                    <p class="experience-card__period">{{ item.period }}</p>
                    <p>{{ item.summary }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    <section class="section section--panel section--panel-mint">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Repères</p>
                <h2>Quelques lignes de force</h2>
            </div>
        </div>

        <div class="card-grid card-grid--three">
            {% for item in journey %}
                <article class="surface-card narrative-card narrative-card--playful">
                    <p class="panel-label">Axe</p>
                    <h3>{{ item.title }}</h3>
                    <p>{{ item.body }}</p>
                </article>
            {% endfor %}
        </div>
    </section>

    <section class="section split-section section--panel section--panel-sky">
        <article class="surface-card">
            <p class="eyebrow">Environnement de travail</p>
            <h2>Des outils choisis pour rester autonome</h2>
            <ul class="feature-list">
                {% for item in environment %}
                    <li>{{ item }}</li>
                {% endfor %}
            </ul>
        </article>

        <article class="surface-card">
            <p class="eyebrow">Passions</p>
            <h2>IA, poésie, musique</h2>
            <ul class="feature-list">
                {% for item in passions %}
                    <li>{{ item }}</li>
                {% endfor %}
            </ul>

            {% if albumUrl %}
                <a class="button" href="{{ albumUrl }}" target="_blank" rel="noreferrer">Écouter l’album</a>
            {% else %}
                <p class="hint-text">Le lien vers l’album est prêt à être branché via la variable d’environnement <code>APP_ALBUM_URL</code>.</p>
            {% endif %}
        </article>
    </section>

    <section class="section section--panel section--panel-sun">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Formations</p>
                <h2>Formations et retours de terrain</h2>
            </div>
        </div>

        <div class="split-section">
            <div class="training-grid">
                {% for item in trainingTimeline %}
                    <article class="surface-card training-card training-card--{{ item.theme }}">
                        <div class="training-card__head">
                            {% if item.imagePath %}
                                <img src="{{ asset(item.imagePath) }}" alt="{{ item.schoolName }}">
                            {% endif %}
                            <div>
                                <p class="panel-label">{{ item.period }}</p>
                                <h3>{{ item.schoolName }}</h3>
                            </div>
                        </div>
                        <p class="experience-card__role">{{ item.program }}</p>
                        <p>{{ item.summary }}</p>
                    </article>
                {% endfor %}
            </div>

            <article class="surface-card">
                <p class="panel-label">Témoignages</p>
                <h3>Ce qu’ils ont pensé de moi</h3>
                <div class="card-grid card-grid--compact">
                    {% for item in testimonials %}
                        <article class="surface-card narrative-card">
                            <p class="panel-label">{{ item.companyName ?: 'Référence' }}</p>
                            <h3>{{ item.authorName }}</h3>
                            {% if item.authorRole %}
                                <p class="stack-line">{{ item.authorRole }}</p>
                            {% endif %}
                            <p>“{{ item.content }}”</p>
                        </article>
                    {% else %}
                        <article class="surface-card narrative-card">
                            <p class="panel-label">Témoignages</p>
                            <h3>Aucun témoignage publié</h3>
                            <p>Ajoute tes premiers retours depuis l’espace admin pour alimenter cette section.</p>
                        </article>
                    {% endfor %}
                </div>
            </article>
        </div>
    </section>

    <section class="section section--panel section--panel-mint">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Présence</p>
                <h2>Réseaux et univers publics</h2>
            </div>
        </div>

        <div class="network-grid">
            {% for item in networkCards %}
                <article class="surface-card network-card network-card--{{ item.theme }}">
                    <div class="network-card__badge" aria-hidden="true">
                        {% if item.theme == 'github' %}
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path fill="currentColor" d="M12 1.5a10.5 10.5 0 0 0-3.32 20.46c.52.1.7-.23.7-.5v-1.95c-2.86.62-3.46-1.38-3.46-1.38-.47-1.2-1.14-1.51-1.14-1.51-.93-.64.07-.63.07-.63 1.03.08 1.57 1.05 1.57 1.05.9 1.56 2.38 1.1 2.97.83.1-.67.36-1.1.65-1.36-2.28-.26-4.67-1.14-4.67-5.08 0-1.12.4-2.04 1.04-2.76-.1-.26-.45-1.31.1-2.72 0 0 .85-.27 2.78 1.05a9.5 9.5 0 0 1 5.06 0c1.93-1.32 2.78-1.05 2.78-1.05.55 1.4.2 2.46.1 2.72.65.72 1.04 1.64 1.04 2.76 0 3.95-2.4 4.82-4.69 5.08.37.31.7.92.7 1.87v2.76c0 .27.19.6.71.5A10.5 10.5 0 0 0 12 1.5Z"/>
                            </svg>
                        {% elseif item.theme == 'linkedin' %}
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path fill="currentColor" d="M5.34 8.2a1.79 1.79 0 1 1 0-3.58 1.79 1.79 0 0 1 0 3.58ZM3.78 9.57h3.13V20.2H3.78V9.57Zm5.03 0h3v1.45h.04c.41-.78 1.44-1.6 2.96-1.6 3.17 0 3.76 2.08 3.76 4.79v5.99h-3.13v-5.31c0-1.27-.02-2.9-1.77-2.9-1.78 0-2.05 1.38-2.05 2.8v5.41H8.81V9.57Z"/>
                            </svg>
                        {% else %}
                            <span>{{ item.badge }}</span>
                        {% endif %}
                    </div>
                    <div class="network-card__copy">
                        <p class="panel-label">{{ item.kicker }}</p>
                        <h3 data-controller="pretext" data-pretext-line-height-value="38">{{ item.title }}</h3>
                        {% if item.subtitle %}
                            <p class="stack-line">{{ item.subtitle }}</p>
                        {% endif %}
                        <p>{{ item.description }}</p>
                    </div>
                    {% if item.url %}
                        <a class="button button--ghost" href="{{ item.url }}" target="_blank" rel="noreferrer">Ouvrir</a>
                    {% endif %}
                </article>
            {% endfor %}

            <article class="surface-card link-card link-card--project">
                <p class="panel-label">Projet</p>
                <h3>Civitalisme</h3>
                <p>Une doctrine prospective européenne articulant sécurité économique, souveraineté numérique et redistribution du dividende technologique.</p>
                <a class="button button--ghost" href="{{ path('app_civitalisme') }}">Explorer</a>
            </article>

            {% for item in hobbyCards %}
                <article class="surface-card link-card link-card--{{ item.theme }}">
                    <p class="panel-label">{{ item.kicker }}</p>
                    <h3>{{ item.title }}</h3>
                    {% if item.subtitle %}
                        <p class="stack-line">{{ item.subtitle }}</p>
                    {% endif %}
                    <p>{{ item.description }}</p>
                    {% if item.url %}
                        <a class="button button--ghost" href="{{ item.url }}" target="_blank" rel="noreferrer">Découvrir</a>
                    {% endif %}
                </article>
            {% endfor %}

            {% if hobbyCards is empty %}
                <article class="surface-card link-card">
                    <p class="panel-label">Écoute</p>
                    <h3>Album et univers personnel</h3>
                    <p>Une autre facette de mon travail, plus sensible et musicale, qui nourrit aussi ma manière de concevoir le web.</p>
                    {% if albumUrl %}
                        <a class="button button--ghost" href="{{ albumUrl }}" target="_blank" rel="noreferrer">Écouter</a>
                    {% else %}
                        <span class="hint-text">Lien d’album à connecter via <code>APP_ALBUM_URL</code>.</span>
                    {% endif %}
                </article>
            {% endif %}
        </div>
    </section>
{% endblock %}
